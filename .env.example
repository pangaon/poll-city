# ─────────────────────────────────────────────────────────────────
# Poll City — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/pollcity
# Managed: Use your provider's connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/pollcity"

# ── NextAuth ─────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Custom Domains ───────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN="pollcity.com"

# ── OAuth Providers (Optional) ───────────────────────────────────
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Apple OAuth
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# ── AI Assist (Optional — stub works without these) ──────────────
# Uncomment and fill to enable live AI responses
# AI_PROVIDER="anthropic"  # or "openai"
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Poll City"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional: Email (for notifications, future use) ──────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@yourdomain.com"
# SMTP_PASS="your-smtp-password"
# EMAIL_FROM="Poll City <noreply@yourdomain.com>"

# ── Security (ALL REQUIRED IN PRODUCTION) ────────────────────────
# Generate each with: openssl rand -base64 32

# One-way hash for IP addresses — used only to prevent duplicate anonymous voting.
# REQUIRED: anonymous voting is disabled if unset (votes rejected with 503).
IP_HASH_SALT="change-this-to-a-random-string-in-production"

# One-way hash for poll vote identity — prevents double voting without storing voter identity.
# REQUIRED: must be set before any public polls go live.
POLL_ANONYMITY_SALT="change-this-to-a-random-string-in-production"

# HMAC secret for guest civic passport tokens (Social onboarding).
# REQUIRED: guest onboarding is broken if unset (falls back to NEXTAUTH_SECRET).
GUEST_TOKEN_SECRET="change-this-to-a-random-string-in-production"

# Secret for autonomous content ingest cron endpoint.
# REQUIRED: endpoint returns 503 if unset (fail closed — endpoint cannot be triggered).
CRON_SECRET="change-this-to-a-random-string-in-production"

# ── Stripe (Platform billing — Poll City subscriptions) ─────────
# Get from stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Platform subscription Price IDs (created in your Stripe dashboard)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# Webhook signing secret for /api/stripe/webhook (platform billing events)
# Get from stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Webhook signing secret for /api/fundraising/stripe/webhook (campaign donation events)
# Register /api/fundraising/stripe/webhook as a SEPARATE endpoint in Stripe Dashboard.
# Events to enable: payment_intent.succeeded, payment_intent.payment_failed,
#   invoice.payment_succeeded, invoice.payment_failed,
#   customer.subscription.deleted, charge.refunded
STRIPE_FUNDRAISING_WEBHOOK_SECRET="whsec_..."

# ── Push Notifications ───────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
