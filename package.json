{
  "name": "poll-city",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:election-results": "tsx prisma/seeds/ingest-election-results.ts",
    "db:seed:officials": "tsx prisma/seeds/ingest-representatives.ts",
    "db:seed:boundaries": "tsx prisma/seeds/ingest-boundaries.ts",
    "db:seed:boundaries:gis": "tsx prisma/seeds/ingest-gis-boundaries.ts",
    "db:seed:all": "npm run db:seed:election-results && npm run db:seed:officials && npm run db:seed:boundaries",
    "db:dedup:election-results": "tsx prisma/seeds/dedup-election-results.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "db:indexes": "psql $DATABASE_URL -f prisma/setup-indexes.sql"
  },
  "prisma": {
    "seed": "npm run db:seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.15.0",
    "@stripe/stripe-js": "^9.0.1",
    "@types/leaflet": "^1.9.4",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.395.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "papaparse": "^5.4.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.52.0",
    "react-is": "^19.2.4",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "sonner": "^1.5.0",
    "stripe": "^22.0.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5"
  }
}
