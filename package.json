{
  "name": "poll-city",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "verify:regression": "npm run docs:check:master && npm run security:gates && npm run test:contracts && npm run test && npm run build",
    "push:safe": "node scripts/push-safe.mjs",
    "push:safe:check": "node scripts/push-safe.mjs --no-push",
    "push:manifest": "node scripts/push-guard-manifest.mjs",
    "guard:learn": "node scripts/guard-learn.mjs",
    "guard:ops": "node scripts/guard-ops-readiness.mjs",
    "video:plan": "node scripts/video-autoplan.mjs",
    "security:gates": "node scripts/security-gates.mjs",
    "docs:check:master": "node scripts/master-doc-consistency.mjs",
    "test:contracts": "node scripts/contract-tests.mjs",
    "ai:ops:daily": "node scripts/ai-ops-daily.mjs",
    "adoni:train": "tsx scripts/train-adoni.ts",
    "verify:api": "tsx scripts/verify-api-routes.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:ward20": "tsx prisma/seeds/ward20-demo.ts",
    "db:seed:calendar": "tsx prisma/seeds/calendar-demo.ts",
    "db:seed:election-results": "tsx prisma/seeds/ingest-election-results.ts",
    "db:seed:toronto-council": "tsx prisma/seeds/toronto-city-council.ts",
    "db:seed:officials": "tsx prisma/seeds/ingest-representatives.ts",
    "db:seed:mps": "tsx prisma/seeds/import-federal-mps.ts",
    "db:seed:mpps": "tsx prisma/seeds/import-ontario-mpps.ts",
    "db:seed:print-templates": "tsx prisma/seeds/print-templates.ts",
    "db:seed:voters": "tsx prisma/seeds/sample-voters.ts",
    "db:seed:volunteers": "tsx prisma/seeds/sample-volunteers.ts",
    "db:seed:toronto-mayor": "tsx prisma/seeds/toronto-mayoral-campaign.ts",
    "db:seed:sample": "npm run db:seed:voters && npm run db:seed:volunteers",
    "db:seed:boundaries": "tsx prisma/seeds/ingest-boundaries.ts",
    "db:seed:boundaries:gis": "tsx prisma/seeds/ingest-gis-boundaries.ts",
    "db:seed:all": "npm run db:seed:election-results && npm run db:seed:officials && npm run db:seed:boundaries",
    "seed:canvasser:demo": "node scripts/seed-canvasser-demo.mjs",
    "db:update-2025": "tsx prisma/seeds/update-officials-2025.ts",
    "db:dedup:election-results": "tsx prisma/seeds/dedup-election-results.ts",
    "db:dedupe": "tsx prisma/seeds/deduplicate-officials.ts",
    "db:dedupe:officials": "tsx prisma/seeds/deduplicate-officials.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "db:indexes": "psql $DATABASE_URL -f prisma/setup-indexes.sql",
    "bridge": "node scripts/bridge.mjs",
    "scrape:toronto": "tsx scripts/scraper/run.ts --municipality toronto",
    "scrape:toronto:dry": "tsx scripts/scraper/run.ts --municipality toronto --dry-run",
    "scrape:install-browsers": "playwright install chromium"
  },
  "prisma": {
    "seed": "npm run db:seed"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.15.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@stripe/stripe-js": "^9.0.1",
    "@turf/turf": "^7.3.4",
    "@types/dompurify": "^3.0.5",
    "@types/shapefile": "^0.6.4",
    "@types/unzipper": "^0.10.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "@watergis/maplibre-gl-export": "^4.1.2",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jose": "^4.15.9",
    "lucide-react": "^0.395.0",
    "maplibre-gl": "^5.23.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "otplib": "^13.4.0",
    "papaparse": "^5.4.1",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.52.0",
    "react-is": "^19.2.4",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "shapefile": "^0.6.6",
    "sharp": "^0.34.5",
    "sonner": "^1.5.0",
    "stripe": "^22.0.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.13.1",
    "unzipper": "^0.12.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.7",
    "typescript": "^5",
    "ws": "^8.20.0"
  }
}
