{
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-officials",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/adoni-briefing",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/claim-outreach",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/adoni-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/adoni-train",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/security-scan",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-imports",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/voice-broadcaster",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/geocode-contacts",
      "schedule": "0 * * * *"
    }
  ]
}