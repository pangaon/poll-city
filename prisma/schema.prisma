  // Field Ops Domain
  fieldTargets             FieldTarget[]
  fieldAttempts            FieldAttempt[]
  followUpActions          FollowUpAction[]

  @@index([campaignId])
  @@index([lastName, firstName])
  @@index([supportLevel])
  @@index([postalCode])
  @@index([email])
  @@index([phone])
  @@index([campaignId, supportLevel])
  @@index([campaignId, deletedAt])
  @@map("contacts")
}

model Tag {
