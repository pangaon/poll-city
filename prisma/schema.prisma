  rejectionReason String?
  deletedAt       DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  budgetLine BudgetLine? @relation(fields: [budgetLineId], references: [id])
  user       User        @relation("ReimbursementUser", fields: [userId], references: [id])
  approver   User?       @relation("ReimbursementApprover", fields: [approverUserId], references: [id])
  expenses   FinanceExpense[]

  @@index([campaignId, status])
  @@index([userId])
  @@map("finance_reimbursements")
}

model BudgetTransfer {
  id                String                      @id @default(cuid())
  campaignId        String
  campaignBudgetId  String
  fromBudgetLineId  String
  toBudgetLineId    String
  amount            Decimal                     @db.Decimal(12, 2)
  reason            String
  requestedByUserId String
  approvedByUserId  String?
  status            FinanceBudgetTransferStatus @default(pending)
  transferDate      DateTime?
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignBudget CampaignBudget @relation(fields: [campaignBudgetId], references: [id], onDelete: Cascade)
  fromLine       BudgetLine     @relation("TransferFrom", fields: [fromBudgetLineId], references: [id])
  toLine         BudgetLine     @relation("TransferTo", fields: [toBudgetLineId], references: [id])
  requestedBy    User           @relation("TransferRequestedBy", fields: [requestedByUserId], references: [id])
  approvedBy     User?          @relation("TransferApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([campaignId, status])
  @@index([campaignBudgetId])
  @@map("budget_transfers")
}

model FinanceAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  entityType   String
  entityId     String
  action       String
  oldValueJson Json?
  newValueJson Json?
  actorUserId  String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("finance_audit_logs")
}

model FinanceAsset {
  id           String    @id @default(cuid())
  campaignId   String
  uploadedById String?
  assetType    String    // receipt | invoice | quote | proof_of_payment | contract | other
  fileUrl      String
  fileName     String
  fileSize     Int?
  mimeType     String?
  hash         String?   // SHA-256 for duplicate detection
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  campaign     Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  uploadedBy   User?            @relation("AssetUploadedBy", fields: [uploadedById], references: [id])
  asReceiptFor FinanceExpense[] @relation("ExpenseReceipt")
  asInvoiceFor FinanceExpense[] @relation("ExpenseInvoice")
  vendorBills  FinanceVendorBill[]

  @@index([campaignId])
  @@index([hash])
  @@map("finance_assets")
}


// ─────────────────────────────────────────────────────────────────────────────
// CALENDAR & SCHEDULING SUITE — PHASE 1 DOMAIN MODEL
// The campaign time-and-coordination operating system.
// ─────────────────────────────────────────────────────────────────────────────

enum CalendarType {
  master
  candidate
  volunteer
  field_ops
  print_production
  events
  communications
  approvals
}

enum CalendarItemType {
  campaign_event
  candidate_appearance
  staff_meeting
  donor_meeting
  debate
  media_appearance
  fundraiser
  town_hall
  community_meeting
  volunteer_shift_item
  canvassing_run
  literature_drop_item
  sign_install_item
  sign_removal_item
  phone_bank_item
  poll_day_ops
  scrutineer_duty
  print_deadline
  vendor_appointment
  delivery_window
  inventory_pickup
  email_blast_item
  sms_blast_item
  social_post_item
  voice_broadcast_item
  press_release
  approval_deadline
  internal_deadline
  milestone
  travel_block
  protected_time
  prep_window
  setup_teardown
  other_item
}

enum CalendarItemStatus {
  draft
  tentative
  scheduled
  confirmed
  in_progress
  completed
  cancelled
  postponed
  no_show
}

enum CalLocationType {
  in_person
  virtual
  phone
  hybrid
  tbd
}

enum ConflictType {
  person_double_booked
  team_double_booked
  location_conflict
  resource_conflict
  inventory_conflict
  deadline_missed
  travel_infeasible
  protected_time_override
  dependency_unmet
  capacity_exceeded
  comm_blackout_violation
}

enum ConflictSeverity {
  info
  warning
  blocking
}

enum CalReminderChannel {
  in_app
  email
  sms
  push
}

enum CalReminderStatus {
  pending
  sent
  failed
  cancelled
}

enum DependencyType {
  finish_to_start
  start_to_start
  finish_to_finish
  start_to_finish
}

enum AvailabilityType {
  available
  unavailable
  tentative
  busy
  out_of_office
  preferred
}

enum CalResourceType {
  vehicle
  venue
  equipment
  inventory_item
  print_material
  volunteer_team
  vendor
}

enum ReservationStatus {
  requested
  confirmed
  released
  cancelled
  conflict
}

model Calendar {
  id               String       @id @default(cuid())
  campaignId       String
  name             String
  description      String?
  calendarType     CalendarType @default(master)
  color            String       @default("#1D9E75")
  visibility       String       @default("internal")
  isDefault        Boolean      @default(false)
  isActive         Boolean      @default(true)
  createdByUserId  String
  updatedByUserId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  items    CalendarItem[]

  @@unique([campaignId, name])
  @@index([campaignId, calendarType])
  @@index([campaignId, isDefault])
  @@map("calendars")
}

model CalendarItem {
  id                      String             @id @default(cuid())
  campaignId              String
  calendarId              String?
  parentCalendarItemId    String?
  title                   String
  description             String?
  itemType                CalendarItemType   @default(other_item)
  itemStatus              CalendarItemStatus @default(scheduled)
  priority                TaskPriority       @default(medium)
  startAt                 DateTime
  endAt                   DateTime
  allDay                  Boolean            @default(false)
  timezone                String             @default("America/Toronto")
  locationType            CalLocationType    @default(in_person)
  locationName            String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  province                String?
  postalCode              String?
  latitude                Float?
  longitude               Float?
  virtualUrl              String?
  ward                    String?
  pollNumber              String?
  turfId                  String?
  eventId                 String?
  taskId                  String?
  fieldAssignmentId       String?
  printJobId              String?
  printOrderId            String?
  signJobIds              String[]           @default([])
  vendorBookingId         String?
  communicationsSendId    String?
  volunteerShiftId        String?
  maxCapacity             Int?
  minCapacity             Int?
  recurrenceRule          String?
  recurrenceParentId      String?
  recurrenceIndex         Int?
  createdByUserId         String
  updatedByUserId         String?
  cancelledAt             DateTime?
  cancellationReason      String?
  deletedAt               DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  campaign        Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  calendar        Calendar?                 @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  createdBy       User                      @relation("CalendarItemCreator", fields: [createdByUserId], references: [id])
  updatedBy       User?                     @relation("CalendarItemUpdater", fields: [updatedByUserId], references: [id])
  parentItem      CalendarItem?             @relation("CalendarItemChildren", fields: [parentCalendarItemId], references: [id])
  childItems      CalendarItem[]            @relation("CalendarItemChildren")
  assignments     CalendarItemAssignment[]
  resources       CalendarItemResource[]
  reminders       CalendarReminder[]
  predecessors    CalendarDependency[]      @relation("DependencySuccessor")
  successors      CalendarDependency[]      @relation("DependencyPredecessor")
  conflictsSource ScheduleConflict[]        @relation("ConflictSource")
  conflictsTarget ScheduleConflict[]        @relation("ConflictTarget")
  checklists      CalendarItemChecklist[]
  @@index([campaignId, startAt])
  @@index([campaignId, itemType, itemStatus])
  @@index([calendarId, startAt])
  @@index([campaignId, eventId])
  @@index([campaignId, fieldAssignmentId])
  @@index([campaignId, volunteerShiftId])
  @@map("calendar_items")
}

model CalendarItemAssignment {
  id                  String    @id @default(cuid())
  calendarItemId      String
  assignedUserId      String?
  assignedVolunteerId String?
  assignedTeamId      String?
  roleOnItem          String?
  responseStatus      String    @default("pending")
  checkInAt           DateTime?
  checkOutAt          DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  calendarItem CalendarItem @relation(fields: [calendarItemId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@unique([calendarItemId, assignedUserId])
  @@index([calendarItemId])
  @@index([assignedUserId])
  @@index([assignedVolunteerId])
  @@index([assignedTeamId])
  @@map("calendar_item_assignments")
}

model CalendarItemResource {
  id                String            @id @default(cuid())
  calendarItemId    String
  resourceType      CalResourceType
  resourceId        String
  resourceLabel     String?
  quantity          Int               @default(1)
  reservationStatus ReservationStatus @default(requested)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  calendarItem CalendarItem @relation(fields: [calendarItemId], references: [id], onDelete: Cascade)

  @@index([calendarItemId])
  @@index([resourceType, resourceId])
  @@map("calendar_item_resources")
}

model AvailabilityBlock {
  id               String           @id @default(cuid())
  campaignId       String
  userId           String?
  volunteerId      String?
  title            String?
  availabilityType AvailabilityType @default(available)
  startAt          DateTime
  endAt            DateTime
  allDay           Boolean          @default(false)
  recurrenceRule   String?
  timezone         String           @default("America/Toronto")
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId, startAt, endAt])
  @@index([userId, startAt])
  @@index([volunteerId, startAt])
  @@map("availability_blocks")
}

model CalendarReminder {
  id              String             @id @default(cuid())
  calendarItemId  String
  reminderType    String             @default("pre_event")
  deliveryChannel CalReminderChannel @default(in_app)
  minutesBefore   Int
  recipientType   String             @default("all_assigned")
  recipientId     String?
  scheduledFor    DateTime?
  status          CalReminderStatus  @default(pending)
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime           @default(now())

  calendarItem CalendarItem @relation(fields: [calendarItemId], references: [id], onDelete: Cascade)

  @@index([calendarItemId])
  @@index([status, scheduledFor])
  @@map("calendar_reminders")
}

model CalendarDependency {
  id                        String         @id @default(cuid())
  campaignId                String
  predecessorCalendarItemId String
  successorCalendarItemId   String
  dependencyType            DependencyType @default(finish_to_start)
  lagMinutes                Int            @default(0)
  ruleBehavior              String         @default("warn")
  createdAt                 DateTime       @default(now())

  predecessor CalendarItem @relation("DependencyPredecessor", fields: [predecessorCalendarItemId], references: [id], onDelete: Cascade)
  successor   CalendarItem @relation("DependencySuccessor", fields: [successorCalendarItemId], references: [id], onDelete: Cascade)

  @@unique([predecessorCalendarItemId, successorCalendarItemId])
  @@index([campaignId])
  @@index([predecessorCalendarItemId])
  @@index([successorCalendarItemId])
  @@map("calendar_dependencies")
}

model ScheduleConflict {
  id                        String           @id @default(cuid())
  campaignId                String
  entityType                String
  entityId                  String
  entityLabel               String?
  conflictType              ConflictType
  sourceCalendarItemId      String
  conflictingCalendarItemId String
  severity                  ConflictSeverity @default(warning)
  status                    String           @default("open")
  detectedAt                DateTime         @default(now())
  resolvedAt                DateTime?
  resolvedByUserId          String?
  resolutionNotes           String?

  campaign        Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourceItem      CalendarItem @relation("ConflictSource", fields: [sourceCalendarItemId], references: [id], onDelete: Cascade)
  conflictingItem CalendarItem @relation("ConflictTarget", fields: [conflictingCalendarItemId], references: [id], onDelete: Cascade)
  resolvedBy      User?        @relation("ConflictResolver", fields: [resolvedByUserId], references: [id])

  @@index([campaignId, status])
  @@index([campaignId, severity, status])
  @@index([sourceCalendarItemId])
  @@map("schedule_conflicts")
}

model ChecklistTemplate {
  id            String    @id @default(cuid())
  campaignId    String?
  name          String
  checklistType String
  description   String?
  isActive      Boolean   @default(true)
  isSystem      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign      Campaign?               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  itemTemplates ChecklistItemTemplate[]
  checklists    CalendarItemChecklist[]

  @@index([campaignId, isActive])
  @@map("checklist_templates")
}

model ChecklistItemTemplate {
  id                  String   @id @default(cuid())
  checklistTemplateId String
  label               String
  sortOrder           Int      @default(0)
  required            Boolean  @default(false)
  itemType            String   @default("checkbox")
  helpText            String?
  createdAt           DateTime @default(now())

  template ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)

  @@index([checklistTemplateId, sortOrder])
  @@map("checklist_item_templates")
}

model CalendarItemChecklist {
  id                  String    @id @default(cuid())
  calendarItemId      String
  checklistTemplateId String?
  title               String?
  createdByUserId     String
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  calendarItem CalendarItem               @relation(fields: [calendarItemId], references: [id], onDelete: Cascade)
  template     ChecklistTemplate?         @relation(fields: [checklistTemplateId], references: [id])
  entries      CalendarItemChecklistEntry[]

  @@index([calendarItemId])
  @@map("calendar_item_checklists")
}

model CalendarItemChecklistEntry {
  id                      String    @id @default(cuid())
  calendarItemChecklistId String
  label                   String
  sortOrder               Int       @default(0)
  required                Boolean   @default(false)
  itemType                String    @default("checkbox")
  valueText               String?
  valueNumber             Float?
  completed               Boolean   @default(false)
  completedAt             DateTime?
  completedByUserId       String?
  photoUrl                String?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  checklist   CalendarItemChecklist @relation(fields: [calendarItemChecklistId], references: [id], onDelete: Cascade)
  completedBy User?                 @relation(fields: [completedByUserId], references: [id])

  @@index([calendarItemChecklistId, sortOrder])
  @@map("calendar_item_checklist_entries")
}

model CalendarAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  entityType   String
  entityId     String
  action       String
  oldValueJson Json?
  newValueJson Json?
  actorUserId  String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User     @relation("CalendarAuditActor", fields: [actorUserId], references: [id])

  @@index([campaignId, entityType, entityId])
  @@index([campaignId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("calendar_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM + CONTACT INTELLIGENCE SUITE — PHASE 1 DOMAIN MODEL
// The campaign relationship and person intelligence operating system.
// ─────────────────────────────────────────────────────────────────────────────

model ContactNote {
  id          String                @id @default(cuid())
  campaignId  String
  contactId   String
  noteType    ContactNoteType       @default(general)
  body        String
  visibility  ContactNoteVisibility @default(all_members)
  isPinned    Boolean               @default(false)
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User     @relation("ContactNoteAuthor", fields: [createdById], references: [id])

  @@index([contactId])
  @@index([campaignId])
  @@map("contact_notes")
}

model ContactRelationship {
  id               String                  @id @default(cuid())
  campaignId       String
  fromContactId    String
  toContactId      String
  relationshipType ContactRelationshipType
  // Inverse relationship type stored to support bidirectional graph
  // e.g. if A→B is "parent", B→A mirror is "child"
  inverseType      ContactRelationshipType?
  strength         Int?                    // 1-5
  notes            String?
  source           String?                 // manual | import | inferred
  isActive         Boolean                 @default(true)
  createdById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromContact  Contact  @relation("RelationshipFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact    Contact  @relation("RelationshipTo", fields: [toContactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, fromContactId, toContactId, relationshipType])
  @@index([fromContactId])
  @@index([toContactId])
  @@map("contact_relationships")
}

model ContactRoleProfile {
  id           String            @id @default(cuid())
  contactId    String
  roleType     ContactRoleType
  roleStatus   ContactRoleStatus @default(active)
  metadataJson Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, roleType])
  @@index([contactId])
  @@map("contact_role_profiles")
}

model SupportProfile {
  id                    String    @id @default(cuid())
  contactId             String    @unique
  // Composite intelligence scores (0-100)
  supportScore          Int?
  turnoutLikelihood     Int?
  persuasionPriority    Int?
  volunteerPotential    Int?
  donorPotential        Int?
  // Issue affinity: { environment: 85, transit: 60, housing: 90 }
  issueAffinityJson     Json?
  // Operational flags
  flagHighValue         Boolean   @default(false) // major donor or major influencer
  flagHighPriority      Boolean   @default(false) // focus canvassing / outreach
  flagHostile           Boolean   @default(false) // do not engage aggressively
  flagDeceased          Boolean   @default(false) // excluded from all outreach
  flagMoved             Boolean   @default(false) // address likely stale
  flagDuplicateRisk     Boolean   @default(false) // suspected duplicate pending review
  flagNeedsFollowUp     Boolean   @default(false) // follow-up action required
  flagComplianceReview  Boolean   @default(false) // donation compliance review pending
  lastAssessedAt        DateTime?
  assessedByUserId      String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("support_profiles")
}

model DuplicateCandidate {
  id               String              @id @default(cuid())
  campaignId       String
  contactAId       String
  contactBId       String
  confidence       DuplicateConfidence
  confidenceScore  Int                 // 0-100
  // Signals that contributed to this score
  // e.g. { emailMatch: true, phoneMatch: false, nameScore: 0.92, addressScore: 0.7 }
  signals          Json
  decision         DuplicateDecision   @default(pending)
  decidedByUserId  String?
  decidedAt        DateTime?
  survivorId       String?             // set after merge completes
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactA  Contact  @relation("DuplicateCandidateA", fields: [contactAId], references: [id], onDelete: Cascade)
  contactB  Contact  @relation("DuplicateCandidateB", fields: [contactBId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactAId, contactBId])
  @@index([campaignId, decision])
  @@map("duplicate_candidates")
}

model MergeHistory {
  id                   String   @id @default(cuid())
  campaignId           String
  survivorContactId    String
  absorbedContactId    String
  mergedByUserId       String
  // Field-level decisions: { supportLevel: "survivor", phone: "absorbed" }
  fieldDecisionsJson   Json
  // Full JSON snapshot of absorbed contact record at time of merge
  absorbedSnapshotJson Json
  createdAt            DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([survivorContactId])
  @@map("merge_history")
}

model ContactAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  contactId    String
  // entity that was changed: contact | note | relationship | role_profile | support_profile
  entityType   String
  entityId     String
  // action taken: created | updated | deleted | merged | support_changed | tag_added | tag_removed | flag_changed
  action       String
  fieldName    String?  // which specific field changed
  oldValueJson Json?
  newValueJson Json?
  actorUserId  String?
  // source of the change: manual | import | api | canvass | automation | system
  source       String   @default("manual")
  createdAt    DateTime @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([campaignId, createdAt])
  @@map("contact_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// FIELD OPS DOMAIN MODEL — PHASE 1
// The field execution nervous system: programs, routes, shifts, targets,
// attempts, follow-ups, teams, and the immutable audit trail.
// All entities are campaignId-scoped. Multi-tenant safe.
// ─────────────────────────────────────────────────────────────────────────────

enum FieldProgramType {
  canvass
  lit_drop
  phone_bank
  sign_install
  sign_remove
  gotv
  event_outreach
  advance_vote
  hybrid
}

enum FieldProgramStatus {
  planning
  active
  paused
  completed
  archived
}

enum RouteStatus {
  draft
  published
  assigned
  in_progress
  completed
  locked
  archived
}

enum FieldTargetStatus {
  pending
  in_progress
  contacted
  no_answer
  not_home
  refused
  moved
  inaccessible
  revisit
  complete
}

enum FieldTargetPriority {
  normal
  high
  urgent
}

enum FieldShiftType {
  canvassing
  literature
  sign_install
  sign_remove
  event_field
  office
  gotv
  poll_day
}

enum FieldShiftStatus {
  draft
  open
  full
  in_progress
  completed
  cancelled
}

enum FieldShiftAssignmentStatus {
  invited
  confirmed
  declined
  checked_in
  completed
  no_show
}

enum ScriptTemplateType {
  id_script
  persuasion
  gotv
  sign_ask
  donor_ask
  volunteer_ask
  general
  follow_up
}

enum FieldAttemptOutcome {
  contacted
  no_answer
  not_home
  moved
  refused
  hostile
  supporter
  undecided
  opposition
  volunteer_interest
  donor_interest
  sign_requested
  follow_up
  bad_data
  inaccessible
  do_not_return
}

enum FollowUpActionType {
  revisit
  sign_ops
  donor_referral
  volunteer_referral
  crm_cleanup
  bad_data
  lit_missed
  building_retry
  gotv_target
  press_opportunity
  other
}

enum FollowUpActionStatus {
  pending
  assigned
  in_progress
  completed
  dismissed
}

enum FieldAuditAction {
  created
  updated
  deleted
  assigned
  started
  completed
  cancelled
  checked_in
  checked_out
  outcome_recorded
  override
  reassigned
}

// ─────────────────────────────────────────────────────────────────────────────

model FieldProgram {
  id             String             @id @default(cuid())
  campaignId     String
  name           String
  description    String?
  programType    FieldProgramType   @default(canvass)
  status         FieldProgramStatus @default(planning)
  targetWard     String?
  targetPolls    String[]           @default([])
  startDate      DateTime?
  endDate        DateTime?
  goalDoors      Int?
  goalContacts   Int?
  goalSupporters Int?
  isActive       Boolean            @default(true)
  createdById    String
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("FieldProgramCreatedBy", fields: [createdById], references: [id])
  routes        Route[]
  shifts        FieldShift[]
  targets       FieldTarget[]
  attempts      FieldAttempt[]
  scriptPackages ScriptPackage[]

  @@index([campaignId, status])
  @@index([campaignId, isActive])
  @@map("field_programs")
}

model Route {
  id               String      @id @default(cuid())
  campaignId       String
  fieldProgramId   String?
  turfId           String?
  name             String
  description      String?
  status           RouteStatus @default(draft)
  ward             String?
  pollNumber       String?
  streets          String[]    @default([])
  oddEven          String      @default("all") // all | odd | even
  totalStops       Int         @default(0)
  totalDoors       Int         @default(0)
  estimatedMinutes Int?
  routeDistance    Float?      // km
  optimizedRoute   Json?       // GeoJSON LineString
  isLocked         Boolean     @default(false)
  notes            String?
  createdById      String
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldProgram FieldProgram? @relation(fields: [fieldProgramId], references: [id])
  turf         Turf?         @relation(fields: [turfId], references: [id])
  createdBy    User          @relation("RouteCreatedBy", fields: [createdById], references: [id])
  targets      FieldTarget[]
  shifts       FieldShift[]
  attempts     FieldAttempt[]

  @@index([campaignId, status])
  @@index([campaignId, fieldProgramId])
  @@map("routes")
}

model FieldTarget {
  id             String              @id @default(cuid())
  campaignId     String
  fieldProgramId String?
  routeId        String?
  contactId      String?
  householdId    String?
  // FK to legacy FieldAssignment — bridges old and new systems during migration
  assignmentId   String?
  priority       FieldTargetPriority @default(normal)
  status         FieldTargetStatus   @default(pending)
  // Reuses existing AssignmentType: canvass | lit_drop | sign_install | sign_remove
  targetType     AssignmentType
  sortOrder      Int                 @default(0)
  notes          String?
  resolvedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldProgram FieldProgram? @relation(fields: [fieldProgramId], references: [id])
  route        Route?        @relation(fields: [routeId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  household    Household?    @relation(fields: [householdId], references: [id])
  attempts     FieldAttempt[]
  followUps    FollowUpAction[]

  @@index([campaignId, status])
  @@index([campaignId, fieldProgramId])
  @@index([routeId, sortOrder])
  @@map("field_targets")
}

model FieldShift {
  id             String           @id @default(cuid())
  campaignId     String
  fieldProgramId String?
  shiftType      FieldShiftType   @default(canvassing)
  name           String
  description    String?
  status         FieldShiftStatus @default(draft)
  scheduledDate  DateTime
  startTime      String           // wall-clock: "09:00"
  endTime        String           // wall-clock: "13:00"
  timezone       String           @default("America/Toronto")
  meetingPoint   String?
  meetingAddress String?
  maxCapacity    Int?
  minCapacity    Int?
  ward           String?
  pollNumber     String?
  turfId         String?
  routeId        String?
  leadUserId     String?
  materialsJson  Json?            // what-to-bring checklist
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  campaign     Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldProgram FieldProgram?          @relation(fields: [fieldProgramId], references: [id])
  turf         Turf?                  @relation(fields: [turfId], references: [id])
  route        Route?                 @relation(fields: [routeId], references: [id])
  leadUser     User?                  @relation("FieldShiftLead", fields: [leadUserId], references: [id])
  assignments  FieldShiftAssignment[]
  attempts     FieldAttempt[]

  @@index([campaignId, scheduledDate])
  @@index([campaignId, fieldProgramId])
  @@index([campaignId, status])
  @@map("field_shifts")
}

model FieldShiftAssignment {
  id                    String                     @id @default(cuid())
  campaignId            String
  shiftId               String
  userId                String?
  volunteerId           String?
  status                FieldShiftAssignmentStatus @default(invited)
  confirmedAt           DateTime?
  checkedInAt           DateTime?
  checkedOutAt          DateTime?
  assignedMaterialsJson Json?
  hoursLogged           Float?
  notes                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shift      FieldShift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user       User?             @relation("FieldShiftAssignmentUser", fields: [userId], references: [id])
  volunteer  VolunteerProfile? @relation("FieldShiftAssignmentVolunteer", fields: [volunteerId], references: [id])

  @@unique([shiftId, userId])
  @@index([campaignId, shiftId])
  @@index([campaignId, userId])
  @@index([campaignId, volunteerId])
  @@map("field_shift_assignments")
}

model ScriptTemplate {
  id                   String             @id @default(cuid())
  campaignId           String
  name                 String
  description          String?
  scriptType           ScriptTemplateType @default(general)
  version              Int                @default(1)
  contentJson          Json               // branching script tree
  targetSupportLevels  SupportLevel[]     @default([])
  language             String             @default("en")
  isActive             Boolean            @default(true)
  createdById          String
  deletedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy     User            @relation("ScriptTemplateCreatedBy", fields: [createdById], references: [id])
  scriptPackages ScriptPackage[] @relation("ScriptPackagePrimary")

  @@index([campaignId, scriptType, isActive])
  @@map("script_templates")
}

model ScriptPackage {
  id              String    @id @default(cuid())
  campaignId      String
  fieldProgramId  String?
  name            String
  description     String?
  primaryScriptId String?
  scriptIds       String[]  @default([]) // Array of ScriptTemplate ids
  isActive        Boolean   @default(true)
  createdById     String
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldProgram   FieldProgram?   @relation(fields: [fieldProgramId], references: [id])
  primaryScript  ScriptTemplate? @relation("ScriptPackagePrimary", fields: [primaryScriptId], references: [id])
  createdBy      User            @relation("ScriptPackageCreatedBy", fields: [createdById], references: [id])

  @@index([campaignId, isActive])
  @@map("script_packages")
}

model FieldAttempt {
  id                   String              @id @default(cuid())
  campaignId           String
  contactId            String?
  householdId          String?
  signId               String?
  fieldProgramId       String?
  routeId              String?
  shiftId              String?
  fieldTargetId        String?
  attemptedById        String
  attemptedAt          DateTime            @default(now())
  outcome              FieldAttemptOutcome
  outcomeNotes         String?
  supportLevelCaptured SupportLevel?
  proofPhotoUrl        String?
  latitude             Float?
  longitude            Float?
  isProxy              Boolean             @default(false) // canvasser reporting for absent resident
  isOfflineSynced      Boolean             @default(false)
  // Reuses existing InteractionSource: canvass | internal_phone | call_center | event | social | self | simulation
  source               InteractionSource   @default(canvass)
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id])
  household    Household?    @relation(fields: [householdId], references: [id])
  sign         Sign?         @relation(fields: [signId], references: [id])
  fieldProgram FieldProgram? @relation(fields: [fieldProgramId], references: [id])
  route        Route?        @relation(fields: [routeId], references: [id])
  shift        FieldShift?   @relation(fields: [shiftId], references: [id])
  fieldTarget  FieldTarget?  @relation(fields: [fieldTargetId], references: [id])
  attemptedBy  User          @relation("FieldAttemptLogger", fields: [attemptedById], references: [id])
  followUps    FollowUpAction[]

  @@index([campaignId, attemptedAt])
  @@index([campaignId, contactId])
  @@index([campaignId, fieldProgramId])
  @@index([campaignId, outcome])
  @@map("field_attempts")
}

model FollowUpAction {
  id             String               @id @default(cuid())
  campaignId     String
  fieldAttemptId String?
  contactId      String?
  householdId    String?
  signId         String?
  fieldTargetId  String?
  followUpType   FollowUpActionType
  status         FollowUpActionStatus @default(pending)
  priority       FieldTargetPriority  @default(normal)
  dueDate        DateTime?
  assignedToId   String?
  notes          String?
  completedAt    DateTime?
  completedById  String?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldAttempt FieldAttempt? @relation(fields: [fieldAttemptId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  household    Household?    @relation(fields: [householdId], references: [id])
  sign         Sign?         @relation(fields: [signId], references: [id])
  fieldTarget  FieldTarget?  @relation(fields: [fieldTargetId], references: [id])
  assignedTo   User?         @relation("FollowUpAssignee", fields: [assignedToId], references: [id])
  completedBy  User?         @relation("FollowUpCompleter", fields: [completedById], references: [id])

  @@index([campaignId, status, dueDate])
  @@index([campaignId, followUpType])
  @@index([campaignId, assignedToId])
  @@map("follow_up_actions")
}

model FieldTeam {
  id          String    @id @default(cuid())
  campaignId  String
  name        String
  description String?
  leadUserId  String?
  ward        String?
  isActive    Boolean   @default(true)
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaign  Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadUser  User?             @relation("FieldTeamLead", fields: [leadUserId], references: [id])
  createdBy User              @relation("FieldTeamCreatedBy", fields: [createdById], references: [id])
  members   FieldTeamMember[]

  @@unique([campaignId, name])
  @@index([campaignId, isActive])
  @@map("field_teams")
}

model FieldTeamMember {
  id          String    @id @default(cuid())
  teamId      String
  campaignId  String
  userId      String?
  volunteerId String?
  role        String    @default("member") // "leader" | "member"
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  team      FieldTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign  Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user      User?             @relation("FieldTeamMemberUser", fields: [userId], references: [id])
  volunteer VolunteerProfile? @relation("FieldTeamMemberVolunteer", fields: [volunteerId], references: [id])

  @@unique([teamId, userId])
  @@unique([teamId, volunteerId])
  @@index([teamId])
  @@index([campaignId, userId])
  @@map("field_team_members")
}

model FieldAuditLog {
  id           String           @id @default(cuid())
  campaignId   String
  // entity: field_program | route | field_target | field_shift | field_attempt | follow_up | field_team
  entityType   String
  entityId     String
  action       FieldAuditAction
  oldValueJson Json?
  newValueJson Json?
  actorUserId  String?
  // source: manual | system | automation | mobile | paper_entry | offline_sync
  source       String           @default("manual")
  ipAddress    String?
  createdAt    DateTime         @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("FieldAuditActor", fields: [actorUserId], references: [id])

  @@index([campaignId, entityType, entityId])
  @@index([campaignId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("field_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNICATIONS PLATFORM — MESSAGE TEMPLATES
// Reusable email + SMS content. Replaces campaign.customization.templates JSON.
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id          String                 @id @default(cuid())
  campaignId  String
  createdById String
  channel     MessageTemplateChannel
  name        String
  subject     String?                // email only
  bodyHtml    String?                // email: full HTML content
  bodyText    String                 // SMS: message body; email: plain text fallback
  previewText String?                // email preview snippet shown in inbox
  // Token inventory: which {{tokens}} appear in this template's body
  tokensUsed  String[]               @default([])
  isActive    Boolean                @default(true)
  deletedAt   DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation("MessageTemplateAuthor", fields: [createdById], references: [id])

  @@index([campaignId, channel])
  @@index([campaignId, isActive])
  @@map("message_templates")
}
