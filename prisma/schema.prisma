  outgoingRelationships    ContactRelationship[]  @relation("RelationshipFrom")
  incomingRelationships    ContactRelationship[]  @relation("RelationshipTo")
  roleProfiles             ContactRoleProfile[]
  supportProfile           SupportProfile?
  duplicateCandidatesA     DuplicateCandidate[]   @relation("DuplicateCandidateA")
  duplicateCandidatesB     DuplicateCandidate[]   @relation("DuplicateCandidateB")
