// VOLUNTEER MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model VolunteerProfile {
  id               String   @id @default(cuid())
  // Volunteer is either a registered user OR a field-captured contact (or both)
  userId           String?  @unique // set if they have a login
  contactId        String?  @unique // set if captured in field without login
  campaignId       String? // which campaign they volunteered for
  skills           String[] @default([])
  availability     String? // free text: "weekends", "evenings after 6pm"
  availabilityJson Json? // structured: { mon: true, tue: false, ... }
  maxHoursPerWeek  Int?
  hasVehicle       Boolean  @default(false)
  notes            String?
  totalHours       Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  deletedById      String?

  user              User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact           Contact?               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign          Campaign?              @relation(fields: [campaignId], references: [id])
  ledGroups          VolunteerGroup[]       @relation("VolunteerGroupLeader")
  groupMemberships   VolunteerGroupMember[]
  shiftSignups       VolunteerShiftSignup[]
  submittedExpenses  VolunteerExpense[]
  fieldAssignments   FieldAssignment[]      @relation("FieldAssignmentVolunteer")
  fieldShiftAssignments FieldShiftAssignment[] @relation("FieldShiftAssignmentVolunteer")
  fieldTeamMemberships  FieldTeamMember[]      @relation("FieldTeamMemberVolunteer")

