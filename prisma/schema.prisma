// Live approval rating for every elected official.
// Score calculated from weighted sentiment signals. Range 0-100 (display) and -100..+100 (net).
model ApprovalRating {
  id            String   @id @default(cuid())
  officialId    String   @unique
  score         Float    @default(50) // 0-100 display score
  netScore      Float    @default(0) // -100..+100 net score
  totalSignals  Int      @default(0)
  positiveCount Int      @default(0)
  negativeCount Int      @default(0)
  neutralCount  Int      @default(0)
  marginOfError Float    @default(3.5)
  velocity      Float    @default(0)
  demographicBreakdown Json?
  updatedAt     DateTime @updatedAt

  official Official          @relation(fields: [officialId], references: [id], onDelete: Cascade)
  history  ApprovalHistory[]

  @@index([score])
  @@index([updatedAt])
  @@map("approval_ratings")
}

// Time-series history of approval scores for trend analysis.
model ApprovalHistory {
  id         String   @id @default(cuid())
  approvalId String
  score      Float
  netScore   Float
  signalType String // which signal triggered this recalc
  recordedAt DateTime @default(now())

  approval ApprovalRating @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@index([approvalId, recordedAt])
  @@map("approval_history")
}

