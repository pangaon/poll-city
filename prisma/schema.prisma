// ─────────────────────────────────────────────────────────────────────────────
// CUSTOM FIELD DEFINITIONS (per-campaign configurable fields)
// ─────────────────────────────────────────────────────────────────────────────

enum FieldType {
  text
  textarea
  boolean
  number
  date
  select // single-select from options list
  multiselect // multi-select from options list
}

enum FieldCategory {
  contact_info // shown on contact card
  canvassing // shown in walk list / canvass view
  membership // party membership fields
  electoral // electoral geography fields
  custom // user-defined
}

model CampaignField {
  id         String        @id @default(cuid())
  campaignId String
  key        String // internal key, e.g. "hydro_concern"
  label      String // display label, e.g. "Hydro Concern"
  fieldType  FieldType     @default(text)
  category   FieldCategory @default(custom)
  options    String[]      @default([]) // for select/multiselect
  isVisible  Boolean       @default(true)
  isRequired Boolean       @default(false)
  showOnCard Boolean       @default(true) // show in canvassing card
  showOnList Boolean       @default(false) // show in contact table
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())

  campaign Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  values   CustomFieldValue[]

  @@unique([campaignId, key])
  @@map("campaign_fields")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOM FIELD VALUES
// Stores actual values for custom fields per contact.
// Separate table = fully queryable, filterable, exportable.
// Standard fields stay as real columns on Contact for performance.
// ─────────────────────────────────────────────────────────────────────────────

model CustomFieldValue {
  id        String    @id @default(cuid())
  contactId String
  fieldId   String // references CampaignField.id
  fieldKey  String // denormalized for fast lookup without join
  // Value stored in appropriate column based on fieldType
  valueText String? // text, textarea, select
  valueBool Boolean? // boolean
  valueNum  Float? // number
  valueDate DateTime? // date
  valueList String[]  @default([]) // multiselect
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contact Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  field   CampaignField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, fieldId])
  @@index([contactId])
  @@index([fieldId])
  @@index([fieldKey, valueText]) // for filtering by field value
  @@index([fieldKey, valueBool])
  @@map("custom_field_values")
}

