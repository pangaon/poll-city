// ─────────────────────────────────────────────────────────────────────────────
// VOICE COMMUNICATIONS (Robocalls, Voice Drops, IVR Polls)
// ─────────────────────────────────────────────────────────────────────────────

model VoiceBroadcast {
  id              String    @id @default(cuid())
  campaignId      String
  createdById     String
  name            String
  type            String    // robocall | voice_drop | ivr_poll
  status          String    @default("draft") // draft | scheduled | in_progress | paused | completed | cancelled
  audioUrl        String?   // pre-recorded audio file URL
  twimlScript     String?   // TwiML for IVR
  ivrQuestions    Json?     // IVR question config for polls
  targetAudience  Json?     // filter criteria for contacts
  totalContacts   Int       @default(0)
  completedCalls  Int       @default(0)
  answeredCalls   Int       @default(0)
  failedCalls     Int       @default(0)
  optOutCount     Int       @default(0)
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // CRTC compliance
  crtcCompliant   Boolean   @default(false)
  callerId        String?   // must be valid Canadian number
  callerIdName    String?
  doNotCallChecked Boolean  @default(false)
  consentVerified Boolean   @default(false)
  callWindowStart String?   // e.g. "09:00" (CRTC: 9am-9:30pm local)
  callWindowEnd   String?   // e.g. "21:30"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign  Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("VoiceBroadcastCreator", fields: [createdById], references: [id])
  calls     VoiceBroadcastCall[]

  @@index([campaignId, status])
  @@index([status, scheduledFor])
  @@map("voice_broadcasts")
}

model VoiceBroadcastCall {
  id            String    @id @default(cuid())
  broadcastId   String
  contactId     String
  phone         String
  status        String    @default("queued") // queued | ringing | answered | completed | failed | busy | no_answer | voicemail | opted_out
  duration      Int?      // seconds
  twilioSid     String?   // Twilio call SID
  ivrResponses  Json?     // keypress responses for IVR polls
  supportLevel  String?   // extracted from IVR response
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  broadcast VoiceBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
  @@index([contactId])
  @@map("voice_broadcast_calls")
}

model VoiceOptOut {
  id         String   @id @default(cuid())
