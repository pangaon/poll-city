model VoiceBroadcast {
  id              String    @id @default(cuid())
  campaignId      String
  createdById     String
  name            String
  type            String    // robocall | voice_drop | ivr_poll
  status          String    @default("draft") // draft | scheduled | in_progress | paused | completed | cancelled
  audioUrl        String?   // pre-recorded audio file URL
  twimlScript     String?   // TwiML for IVR
  ivrQuestions    Json?     // IVR question config for polls
  targetAudience  Json?     // filter criteria for contacts
  totalContacts   Int       @default(0)
  completedCalls  Int       @default(0)
  answeredCalls   Int       @default(0)
  failedCalls     Int       @default(0)
  optOutCount     Int       @default(0)
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // CRTC compliance
  crtcCompliant   Boolean   @default(false)
  callerId        String?   // must be valid Canadian number
  callerIdName    String?
  doNotCallChecked Boolean  @default(false)
  consentVerified Boolean   @default(false)
  callWindowStart String?   // e.g. "09:00" (CRTC: 9am-9:30pm local)
  callWindowEnd   String?   // e.g. "21:30"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign  Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("VoiceBroadcastCreator", fields: [createdById], references: [id])
