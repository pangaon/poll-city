// ═══════════════════════════════════════════════════════════════════════════
// POLL CITY ECOSYSTEM — FULL PRISMA SCHEMA
// Serves both Poll City (campaign ops) and Poll City Social (public civic app)
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  CAMPAIGN_MANAGER
  VOLUNTEER
  VOLUNTEER_LEADER
  PUBLIC_USER
}

enum SupportLevel {
  strong_support
  leaning_support
  undecided
  leaning_opposition
  strong_opposition
  unknown
}

enum InteractionType {
  door_knock
  phone_call
  text
  email
  event
  note
  follow_up
  field_encounter
  funnel_transition
}

enum FunnelStage {
  unknown
  contact
  supporter
  volunteer
  donor
  voter
}

enum ElectionType {
  municipal
  provincial
  federal
  by_election
  other
}

enum SubscriptionPlan {
  free_trial
  starter
  pro
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  incomplete
}

enum GovernmentLevel {
  municipal
  provincial
  federal
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum CanvassStatus {
  not_started
  in_progress
  completed
  paused
}

enum PollType {
  binary
  multiple_choice
  ranked
  slider
  swipe // Tinder-style left/right
  image_swipe // swipe on images
  emoji_react // react with emoji
  priority_rank // drag to rank issues
  nps           // 0-10 NPS score
  word_cloud    // free word submission
  timeline_radar // multi-dimension rating
}

enum SwipeDirection {
  left
  right
  up
  down
}

enum PollVisibility {
  public
  campaign_only
  unlisted
}

enum SignStatus {
  requested
  scheduled
  installed
  removed
  declined
}

enum ServiceCategory {
  canvassing
  sign_installation
  lit_drop
  phone_bank
  event_staff
  other
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
}

enum SupportSignalType {
  strong_support
  general_support
  sign_request
  do_not_contact
  volunteer_interest
  question
}

enum GotvStatus {
  not_checked
  not_home
  voted
  will_vote
  refused
}

enum VolunteerInviteStatus {
  pending
  completed
  expired
}

enum VolunteerShiftSignupStatus {
  signed_up
  cancelled
  attended
  no_show
}

enum ScriptType {
  supporter
  persuadable
  opposition
  general
}

enum SentimentType {
  positive
  neutral
  negative
}

enum OpponentIntelType {
  sign
  event
  media
  note
}

enum VolunteerExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

enum BudgetItemType {
  allocation
  expense
}

enum EventVisibility {
  internal
  supporters_only
  public
}

enum EventStatus {
  draft
  scheduled
  live
  completed
  cancelled
  archived
}

enum EventRsvpStatus {
  going
  interested
  not_going
  waitlisted
  checked_in
  no_show
}

enum SocialPlatform {
  x
  facebook
  instagram
  linkedin
  tiktok
  youtube
  threads
  bluesky
}

enum SocialAccountStatus {
  active
  disconnected
  error
  paused
}

enum SocialPostStatus {
  draft
  pending_approval
  approved
  scheduled
  publishing
  published
  failed
  cancelled
}

enum SocialMentionSentiment {
  positive
  neutral
  negative
  mixed
  unknown
}

enum CasePriority {
  low
  medium
  high
  urgent
}

enum CaseStatus {
  open
  in_progress
  waiting_on_resident
  waiting_on_agency
  resolved
  closed
}

enum CaseChannel {
  web
  phone
  email
  in_person
  social
  referral
}

// ─────────────────────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  role                 Role      @default(VOLUNTEER)
  avatarUrl            String?
  phone                String?
  // Multi-campaign: which campaign this user is currently viewing
  // Set on login and updated via /api/campaigns/switch
  activeCampaignId     String?
  // Geo fields for Social users
  postalCode           String?
  address              String?
  ward                 String?
  riding               String?
  geoLat               Float?
  geoLng               Float?
  // Social preferences
  emailVerified        Boolean   @default(false)
  pushEnabled          Boolean   @default(true)
  notifyElections      Boolean   @default(true)
  notifyPolls          Boolean   @default(true)
  isActive             Boolean   @default(true)
  lastLoginAt          DateTime?
  // Password reset
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  // Account lockout
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  // Session invalidation nonce (increment to revoke active JWT sessions)
  sessionVersion       Int       @default(0)
  // Two-factor authentication (TOTP)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  twoFactorVerifiedAt  DateTime?
  // Email OTP
  emailOtpCode         String?
  emailOtpExpiry       DateTime?
  emailOtpAttempts     Int       @default(0)
  // SMS OTP
  smsOtpCode           String?
  smsOtpExpiry         DateTime?
  smsOtpAttempts       Int       @default(0)
  // WebAuthn (Face ID, Touch ID, Windows Hello)
  webauthnCredentials  Json      @default("[]")
  // Security preferences
  preferredMfaMethod   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Campaign side
  memberships          Membership[]
  interactions         Interaction[]
  tasksAssigned        Task[]                   @relation("AssignedTasks")
  tasksCreated         Task[]                   @relation("CreatedTasks")
  activityLogs         ActivityLog[]
  canvassAssignments   CanvassAssignment[]
  volunteerProfile     VolunteerProfile?
  donationsRecorded    Donation[]               @relation("RecordedDonations")
  gotvBatchesUploaded  GotvBatch[]              @relation("UploadedGotvBatches")
  subscription         Subscription?
  importLogs           ImportLog[]
  crmColumnPreferences CrmColumnPreference[]
  importTemplates      CampaignImportTemplate[]
  uploadedDocuments    CampaignDocument[]       @relation("UserUploadedDocuments")

  // Turf canvassing
  turfAssignments   Turf[]             @relation("TurfAssignee")
  canvasserLocation CanvasserLocation?

  // Social side
  pollResponses         PollResponse[]
  supportSignals        SupportSignal[]
  officialFollows       OfficialFollow[]
  questions             PublicQuestion[]
  notifications         Notification[]
  consentLogs           ConsentLog[]
  pushSubscriptions     PushSubscription[]
  notificationLogs      NotificationLog[]
  socialPostsAuthored   SocialPost[]          @relation("SocialPostAuthor")
  socialPostsApproved   SocialPost[]          @relation("SocialPostApprover")
  socialPostsRejected   SocialPost[]          @relation("SocialPostRejector")
  socialMentionsOwned   SocialMention[]       @relation("SocialMentionAssignee")
  constituentCasesOwned ConstituentCaseFile[] @relation("ConstituentCaseAssignee")
  constituentCaseNotes  ConstituentCaseNote[]
  volunteerLocations      VolunteerLocation[]
  voiceBroadcastsCreated  VoiceBroadcast[]     @relation("VoiceBroadcastCreator")
  phoneBankSessions       PhoneBankSession[]   @relation("PhoneBankVolunteer")
  debugSessions            DebugSession[]
  newsletterCampaignsAuthored NewsletterCampaign[] @relation("NewsletterAuthor")

  // Civic social
  civicProfile   CivicProfile?    @relation("UserCivicProfile")
  voterPassport  VoterPassport?   @relation("UserVoterPassport")
  civicCredits   CivicCredit[]    @relation("UserCivicCredits")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN
// ─────────────────────────────────────────────────────────────────────────────

model Campaign {
  id                     String       @id @default(cuid())
  name                   String
  slug                   String       @unique
  description            String?
  electionType           ElectionType @default(municipal)
  jurisdiction           String?
  electionDate           DateTime?
  // Election finance spending limits (from EC/provincial regulators)
  spendingLimit          Float?
  partyExpenseLimit      Float?
  candidateName          String?
  candidateTitle         String?
  candidateBio           String?
  candidateEmail         String?
  candidatePhone         String?
  logoUrl                String?
  websiteUrl             String?
  customDomain           String?
  volunteerIntroVideoUrl String?
  volunteerCodeOfConduct String?
  primaryColor           String       @default("#1e40af")
  isPublic               Boolean      @default(false)
  officialId             String?
  isActive               Boolean      @default(true)
  customization          Json?
  pageViews              Int          @default(0)
  // Per-campaign tracking IDs — campaigns paste their own analytics codes
  gaId                   String?      // Google Analytics 4 (G-XXXXXXXXXX)
  metaPixelId            String?      // Meta/Facebook Pixel ID
  googleAdsId            String?      // Google Ads tag (AW-XXXXXXXXXX)
  linkedinPartnerId      String?      // LinkedIn Insight Tag
  tiktokPixelId          String?      // TikTok Pixel
  // Domain verification
  domainStatus           String       @default("not_connected") // not_connected | pending | verified | live
  domainVerifiedAt       DateTime?
  votedDisplayMode       String       @default("strikethrough")
  onboardingComplete     Boolean      @default(false)
  // Campaign-level security enforcement
  require2FA             Boolean      @default(false)
  allowedIpRanges        String[]     @default([])
  sessionTimeoutHours    Int          @default(24)
  dataRetentionDays      Int          @default(365)
  // Brand Kit
  secondaryColor         String?      @default("#d71920")
  accentColor            String?      @default("#f5a623")
  logoPublicId           String?
  fontPrimary            String       @default("inter")
  tagline                String?
  twitterHandle          String?
  facebookUrl            String?
  instagramHandle        String?
  brandKitComplete       Boolean      @default(false)
  // TV Mode
  tvEnabled              Boolean      @default(false)
  tvToken                String?      @unique @default(cuid())
  tvRotate               Boolean      @default(true)
  tvRotateSec            Int          @default(30)
  tvModes                String[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  official                  Official?                  @relation(fields: [officialId], references: [id])
  memberships               Membership[]
  contacts                  Contact[]
  households                Household[]
  canvassLists              CanvassList[]
  tasks                     Task[]
  activityLogs              ActivityLog[]
  tags                      Tag[]
  signs                     Sign[]
  serviceBookings           ServiceBooking[]
  polls                     Poll[]
  campaignFields            CampaignField[]
  donations                 Donation[]
  gotvBatches               GotvBatch[]
  qrCodes                   QrCode[]
  volunteerProfiles         VolunteerProfile[]
  signRequests              SignRequest[]
  questions                 Question[]
  pushSubscriptions         PushSubscription[]
  notificationLogs          NotificationLog[]
  printJobs                 PrintJob[]
  turfs                     Turf[]
  volunteerLocations        VolunteerLocation[]
  mapSettings               MapSettings?
  volunteerOnboardingTokens VolunteerOnboardingToken[]
  volunteerGroups           VolunteerGroup[]
  volunteerShifts           VolunteerShift[]
  canvassingScripts         CanvassingScript[]
  mediaMentions             MediaMention[]
  coalitions                Coalition[]
  opponentIntel             OpponentIntel[]
  events                    Event[]
  socialAccounts            SocialAccount[]
  socialPosts               SocialPost[]
  socialMentions            SocialMention[]
  constituents              Constituent[]
  constituentCaseFiles      ConstituentCaseFile[]
  volunteerExpenses         VolunteerExpense[]
  budgetItems               BudgetItem[]
  budgetRules               BudgetRule[]
  budgetTemplates           BudgetTemplate[]
  contactFilterPresets      ContactFilterPreset[]
  superSupporterTasks       SuperSupporterTask[]
  importLogs                ImportLog[]
  exportLogs                ExportLog[]
  crmColumnPreferences      CrmColumnPreference[]
  importTemplates           CampaignImportTemplate[]
  documents                 CampaignDocument[]
  votedListTemplates        VotedListTemplate[]
  votedListUploads          VotedListUpload[]
  PrintOrder                PrintOrder[]
  MerchProduct              MerchProduct[]
  campaignRoles             CampaignRole[]
  permissionAuditLogs       PermissionAuditLog[]
  voiceBroadcasts           VoiceBroadcast[]
  voiceOptOuts              VoiceOptOut[]
  callCenterIntegrations    CallCenterIntegration[]
  phoneBankSessions         PhoneBankSession[]
  newsletterSubscribers     NewsletterSubscriber[]
  newsletterCampaigns       NewsletterCampaign[]
  forms                     Form[]

  @@unique([customDomain])
  @@index([slug])
  @@index([isPublic, isActive])
  @@map("campaigns")
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  campaignId     String
  role           Role     @default(VOLUNTEER)
  campaignRoleId String?
  trustLevel     Int      @default(2)
  status         String   @default("active")
  joinedAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignRole  CampaignRole? @relation(fields: [campaignRoleId], references: [id])
  assignedTurfs Turf[]        @relation("TurfAssignedVolunteer")

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN ROLES & PERMISSIONS (Enterprise RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model CampaignRole {
  id           String   @id @default(cuid())
  campaignId   String
  name         String
  slug         String
  description  String?
  colour       String   @default("#6b7280")
  permissions  String[]
  trustFloor   Int      @default(1)
  trustCeiling Int      @default(5)
  isSystem     Boolean  @default(false)
  isDefault    Boolean  @default(false)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([campaignId, slug])
  @@index([campaignId])
  @@map("campaign_roles")
}

model PermissionAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  actorUserId  String
  targetUserId String?
  action       String
  before       Json?
  after        Json?
  reason       String?
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@map("permission_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// OFFICIALS / ELECTED REPRESENTATIVES
// ─────────────────────────────────────────────────────────────────────────────

model Official {
  id                 String          @id @default(cuid())
  name               String
  title              String // e.g. "Mayor", "MP", "MPP", "Councillor"
  level              GovernmentLevel
  district           String // ward, riding, or constituency name
  districtCode       String? // official electoral district code
  party              String? // legacy field
  partyName          String? // canonical party name — used for colour lookup
  email              String?
  phone              String?
  website            String?
  photoUrl           String?
  bio                String?
  // Geographic coverage
  postalCodes        String[]        @default([]) // postal prefixes served
  province           String?
  // Profile status
  isClaimed          Boolean         @default(false)
  claimedAt          DateTime?
  claimedByUserId    String?
  subscriptionStatus String?         @default("free") // free | pro | verified
  isActive           Boolean         @default(true)
  // Social media
  twitter            String?
  facebook           String?
  instagram          String?
  linkedIn           String?
  // Extended identity fields
  firstName          String?
  lastName           String?
  address            String?
  // External data provenance
  externalId         String? // e.g. Represent API slug
  externalSource     String? // "represent_opennorth" | "manual" | "open_north"
  termStart          DateTime?
  termEnd            DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  campaigns        Campaign[]
  follows          OfficialFollow[]
  questions        PublicQuestion[]
  polls            Poll[]
  approvalRating   ApprovalRating?
  sentimentSignals SentimentSignal[]
  outreach         OfficialOutreach[]
  constituents     Constituent[]
  caseFiles                ConstituentCaseFile[]
  newsletterSubscribers    NewsletterSubscriber[]
  newsletterCampaigns      NewsletterCampaign[]

  @@index([level, district])
  @@index([postalCodes])
  @@index([province, level])
  @@index([isClaimed])
  @@index([isActive, level])
  @@map("officials")
}

model OfficialFollow {
  userId     String
  officialId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  official Official @relation(fields: [officialId], references: [id], onDelete: Cascade)

  @@id([userId, officialId])
  @@map("official_follows")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACTS / VOTERS (Campaign side)
// ─────────────────────────────────────────────────────────────────────────────

model Household {
  id          String    @id @default(cuid())
  address1    String
  address2    String?
  city        String?
  province    String?
  postalCode  String?
  ward        String?
  riding      String?
  lat         Float?
  lng         Float?
  visited     Boolean   @default(false)
  visitedAt   DateTime?
  totalVoters Int? // from official voter file
  campaignId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contacts Contact[]

  @@map("households")
}

model Contact {
  id                   String       @id @default(cuid())
  campaignId           String
  householdId          String?
  householdRole        String?
  nameTitle            String? // Mr, Ms, Dr, etc
  firstName            String
  middleName           String?
  lastName             String
  nameSuffix           String? // Jr, Sr, III, etc
  gender               String? // M, F, NB, prefer_not_to_say
  email                String?
  phone                String?
  phone2               String?
  address1             String?
  address2             String?
  city                 String?
  province             String?
  postalCode           String?
  ward                 String?
  riding               String?
  supportLevel         SupportLevel @default(unknown)
  funnelStage          FunnelStage  @default(unknown)
  notes                String?
  preferredLanguage    String       @default("en")
  languagePreference   String?
  accessibilityFlag    Boolean      @default(false)
  doNotContact         Boolean      @default(false)
  superSupporter       Boolean      @default(false)
  signRequested        Boolean      @default(false)
  signPlaced           Boolean      @default(false)
  volunteerInterest    Boolean      @default(false)
  gotvStatus           GotvStatus   @default(not_checked)
  facebook             String?
  twitter              String?
  instagram            String?
  wechat               String?
  // Secondary contact
  email2               String?
  businessEmail        String?
  businessPhone        String?
  businessPhoneExt     String?
  phoneAreaCode        String? // stored separately for voter file compatibility
  cellAreaCode         String?
  // Electoral geography (from official voter file)
  federalDistrict      String?
  federalPoll          String?
  provincialDistrict   String?
  provincialPoll       String?
  municipalDistrict    String?
  municipalPoll        String?
  censusDivision       String?
  votingLocation       String?
  votingAddress        String?
  // Flags
  isDeceased           Boolean      @default(false)
  skipHouse            Boolean      @default(false) // canvasser deliberately skipping
  membershipExpiry     DateTime?
  partyMember          Boolean      @default(false)
  // Custom fields stored in CustomFieldValue table (queryable)
  streetNumber         String?
  streetNumberSuffix   String? // A, B, 1/2 etc
  streetName           String?
  streetType           String? // Ave, Blvd, Rd, Dr, St etc
  streetDirection      String? // E, W, N, S, NE etc
  unitApt              String?
  pollDistrict         String?
  // Leadership race fields
  firstChoice          String? // for leadership/nomination races
  secondChoice         String?
  membershipSold       Boolean      @default(false)
  isActiveMember       Boolean      @default(false)
  captain              String?
  subCaptain           String?
  issues               String[]     @default([])
  lastContactedAt      DateTime?
  followUpNeeded       Boolean      @default(false)
  followUpDate         DateTime?
  importSource         String? // csv | canvass | phone | event | web
  externalId           String?
  source               String? // PC | Liberal | NDP | canvass | referral etc
  notHome              Boolean      @default(false)
  totalVotersAtAddress Int?
  voted                Boolean      @default(false)
  votedAt              DateTime?
  votedListUploadId    String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  household           Household?           @relation(fields: [householdId], references: [id])
  tags                ContactTag[]
  interactions        Interaction[]
  tasks               Task[]
  signRequests        Sign[]
  volunteerProfile    VolunteerProfile?
  donations           Donation[]
  gotvRecords         GotvRecord[]
  customFieldValues   CustomFieldValue[]
  turfStops           TurfStop[]
  superSupporterTasks  SuperSupporterTask[]
  constituents         Constituent[]
  eventRsvps           EventRsvp[]
  voiceBroadcastCalls  VoiceBroadcastCall[]

  @@index([campaignId])
  @@index([lastName, firstName])
  @@index([supportLevel])
  @@index([postalCode])
  @@index([email])
  @@index([phone])
  @@index([campaignId, supportLevel])
  @@map("contacts")
}

model Tag {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#6b7280")
  campaignId String
  createdAt  DateTime @default(now())

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([name, campaignId])
  @@map("tags")
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ─────────────────────────────────────────────────────────────────────────────
// CANVASSING
// ─────────────────────────────────────────────────────────────────────────────

model CanvassList {
  id          String        @id @default(cuid())
  campaignId  String
  name        String
  description String?
  status      CanvassStatus @default(not_started)
  geoArea     Json? // GeoJSON polygon for map rendering
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  campaign    Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignments CanvassAssignment[]

  @@map("canvass_lists")
}

model CanvassAssignment {
  id            String        @id @default(cuid())
  canvassListId String
  userId        String
  status        CanvassStatus @default(not_started)
  notes         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  canvassList CanvassList @relation(fields: [canvassListId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("canvass_assignments")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTERACTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Interaction {
  id                String          @id @default(cuid())
  contactId         String
  userId            String
  type              InteractionType
  notes             String?
  supportLevel      SupportLevel?
  issues            String[]        @default([])
  signRequested     Boolean         @default(false)
  volunteerInterest Boolean         @default(false)
  followUpNeeded    Boolean         @default(false)
  followUpDate      DateTime?
  doorNumber        String?
  duration          Int?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime        @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([userId])
  @@map("interactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  campaignId   String
  contactId    String?
  assignedToId String?
  createdById  String
  title        String
  description  String?
  status       TaskStatus   @default(pending)
  priority     TaskPriority @default(medium)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

