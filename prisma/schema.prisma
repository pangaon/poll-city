// These come from poll votes, support signals, question sentiment, follows/unfollows.
model SentimentSignal {
  id         String   @id @default(cuid())
  officialId String
  type       String // "poll_vote" | "support_signal" | "question_sentiment" | "follow" | "unfollow" | "interaction"
  value      Float // -1.0 to 1.0
  weight     Float    @default(1.0)
  source     String // "social_poll" | "candidate_page" | "canvassing" | "social_follow"
  metadata   Json? // e.g. { pollId, contactId, postalPrefix }
  createdAt  DateTime @default(now())

  official Official @relation(fields: [officialId], references: [id], onDelete: Cascade)

  @@index([officialId, createdAt])
  @@index([type])
  @@index([source])
  @@map("sentiment_signals")
}

