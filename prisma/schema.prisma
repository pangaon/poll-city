  @@map("public_questions")
}

// ─────────────────────────────────────────────────────────────────────────────
// GEO REFERENCE (ward/riding lookup by postal code)
// ─────────────────────────────────────────────────────────────────────────────

model GeoDistrict {
  id           String          @id @default(cuid())
  postalPrefix String? // e.g. "M4C", "K1A" — null for boundary-only records
  ward         String?
  wardCode     String?
  riding       String?
  ridingCode   String?
  province     String
  city         String?
  level        GovernmentLevel
  // GIS boundary fields — added for choropleth heat maps
  name         String? // human-readable district/municipality name
  slug         String? // canonical district slug
  districtType String? // "municipal" | "provincial" | "federal"
  externalId   String? // source system identifier
  centroid     Json? // { lat, lng } for map centering
  metadata     Json? // raw source metadata (boundary set, area id, etc.)
  geoJson      Json? // GeoJSON geometry (Polygon or MultiPolygon)
  // Ingestion provenance — which DataSource populated this boundary
  dataSourceId String?
  datasetId    String?
  ingestedAt   DateTime?
  effectiveAt  DateTime? // when this boundary version took effect
  createdAt    DateTime        @default(now())

  dataSource DataSource? @relation(fields: [dataSourceId], references: [id])
  dataset    Dataset?    @relation(fields: [datasetId], references: [id])
  boundaryMemberships BoundaryMembership[]

  @@unique([postalPrefix, level])
  @@index([postalPrefix])
  @@index([province, districtType])
  @@index([name])
  @@index([slug])
  @@index([dataSourceId])
  @@map("geo_districts")
}

// ─────────────────────────────────────────────────────────────────────────────
