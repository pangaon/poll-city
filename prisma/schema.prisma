// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(incomplete)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONSENT LOG
// Records every consent bridge transfer from Poll City Social into the campaign
// CRM. Written on every POST /api/social/signal that executes a bridge transfer.
// Used for user-facing consent display and revocation.
// ─────────────────────────────────────────────────────────────────────────────

model ConsentLog {
  id            String    @id @default(cuid())
  // Who consented
  userId        String
  // Which campaign received the signal
  campaignId    String
  // What type of signal triggered the bridge
  signalType    String // matches SupportSignalType enum values
  // What purpose the user agreed to
  consentScope  String // "campaign_awareness" | "volunteer_contact" | "sign_installation" | "do_not_contact"
  // Which fields were written to the CRM Contact record
  fieldsXferred String[] // e.g. ["postalCode", "ward"] — never includes email/phone unless provided
  // Traceability — links to the ActivityLog entry written at the same time
  activityLogId String?
  // The CRM Contact record created or updated by this bridge transfer
  contactId     String?
  // Revocation — null = active consent, set = revoked
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Idempotency guard: one active consent record per (user, campaign, signalType)
  // A revoked record allows re-consenting (revokedAt IS NOT NULL = inactive)
  @@unique([userId, campaignId, signalType], name: "unique_active_consent")
  @@index([userId])
  @@index([campaignId])
  @@map("consent_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRINT MARKETPLACE
// Campaigns post print jobs, registered print shops bid, campaign awards bid.
// ─────────────────────────────────────────────────────────────────────────────

enum TurfStatus {
  draft
  assigned
  in_progress
  completed
  reassigned
}

enum PrintProductType {
  door_hanger
  lawn_sign
  flyer
  palm_card
  mailer_postcard
  banner
  button_pin
  window_sign
  bumper_sticker
  t_shirt
  hat
  tote_bag
  yard_stake
  table_cover
  lanyard
}

enum PrintJobStatus {
  draft
  posted
  bidding
  awarded
  in_production
  quality_check
  shipped
  delivered
  cancelled
}

model PrintShop {
  id                   String             @id @default(cuid())
  name                 String
  contactName          String?
  email                String
  phone                String?
  website              String?
  description          String?
  serviceAreas         String[]           @default([])
  specialties          PrintProductType[] @default([])
  rating               Float?
  reviewCount          Int                @default(0)
  isVerified           Boolean            @default(false)
  isActive             Boolean            @default(true)
  logoUrl              String?
  stripeAccountId      String?
  stripeOnboarded      Boolean            @default(false)
  portfolio            String[]           @default([])
  provincesServed      String[]           @default([])
  averageResponseHours Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  bids PrintBid[]

  @@map("print_shops")
}

model PrintJob {
  id                String           @id @default(cuid())
  campaignId        String
  userId            String
  productType       PrintProductType
  title             String
  quantity          Int
  description       String?
  specs             Json?
  deadline          DateTime?
  deliveryAddress   String?
  deliveryCity      String?
  deliveryPostal    String?
  fileUrl           String?
  budgetMin         Float?
  budgetMax         Float?
  status            PrintJobStatus   @default(draft)
  awardedBidId      String?
  paymentIntentId   String?
  paymentStatus     String?          @default("pending") // pending | paid | released | refunded
  trackingNumber    String?
  carrier           String?
  estimatedDelivery DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign Campaign   @relation(fields: [campaignId], references: [id])
  bids     PrintBid[]

  @@index([campaignId, status])
  @@map("print_jobs")
}

model PrintBid {
  id         String   @id @default(cuid())
  jobId      String
  shopId     String
  price      Float
  turnaround Int
  notes      String?
  fileUrl    String?
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job  PrintJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  shop PrintShop @relation(fields: [shopId], references: [id])

  @@index([jobId])
  @@index([shopId])
  @@map("print_bids")
}

// ─────────────────────────────────────────────────────────────────────────────
// TURF CUTTING & ROUTE OPTIMIZATION
// ─────────────────────────────────────────────────────────────────────────────

model Turf {
  id              String     @id @default(cuid())
  campaignId      String
  name            String
  boundary        Json?
  centroid        Json?
  ward            String?
  pollNumber      String?
  streets         String[]   @default([])
  oddEven         String     @default("all")
  status          TurfStatus @default(draft)
  assignedUserId  String?
  assignedVolunteerId String?
  assignedGroupId String?
  totalStops      Int        @default(0)
  totalDoors      Int        @default(0)
  completedStops  Int        @default(0)
  doorsKnocked    Int        @default(0)
  completionPercent Float    @default(0)
  supporters      Int        @default(0)
  undecided       Int        @default(0)
  optimizedRoute  Json?
  routeDistance   Float?
  estimatedMinutes Int?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  campaign          Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignedUser      User?            @relation("TurfAssignee", fields: [assignedUserId], references: [id])
  assignedVolunteer Membership?      @relation("TurfAssignedVolunteer", fields: [assignedVolunteerId], references: [id])
  assignedGroup     VolunteerGroup?  @relation(fields: [assignedGroupId], references: [id])
  stops             TurfStop[]
  fieldAssignments  FieldAssignment[]
  routes            Route[]
  fieldShifts       FieldShift[]

  @@index([campaignId])
  @@map("turfs")
}

model VolunteerOnboardingToken {
  id            String                @id @default(cuid())
  token         String                @unique
  campaignId    String
  firstName     String
  lastName      String
  email         String
  phone         String?
  preferredWard String?
  status        VolunteerInviteStatus @default(pending)
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@map("volunteer_onboarding_tokens")
}

model VolunteerGroup {
  id              String   @id @default(cuid())
  campaignId      String
  name            String
  description     String?
  targetWard      String?
  leaderProfileId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign      Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leaderProfile    VolunteerProfile?      @relation("VolunteerGroupLeader", fields: [leaderProfileId], references: [id])
  members          VolunteerGroupMember[]
  turfs            Turf[]
  fieldAssignments FieldAssignment[]      @relation("FieldAssignmentGroup")

  @@unique([campaignId, name])
  @@index([campaignId])
  @@map("volunteer_groups")
}

model VolunteerGroupMember {
  id                 String   @id @default(cuid())
  groupId            String
  volunteerProfileId String
  createdAt          DateTime @default(now())

  group            VolunteerGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  volunteerProfile VolunteerProfile @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)

  @@unique([groupId, volunteerProfileId])
  @@index([volunteerProfileId])
  @@map("volunteer_group_members")
}

model VolunteerShift {
  id              String   @id @default(cuid())
  campaignId      String
  name            String
  shiftDate       DateTime
  startTime       String
  endTime         String
  meetingLocation String
  targetTurfArea  String?
  maxVolunteers   Int      @default(10)
  minVolunteers   Int      @default(1)
  notes           String?
  checkInCode     String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  signups  VolunteerShiftSignup[]

  @@index([campaignId, shiftDate])
  @@map("volunteer_shifts")
}

model VolunteerShiftSignup {
  id                 String                     @id @default(cuid())
  shiftId            String
  volunteerProfileId String
  status             VolunteerShiftSignupStatus @default(signed_up)
  checkedInAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  shift            VolunteerShift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  volunteerProfile VolunteerProfile @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)

  @@unique([shiftId, volunteerProfileId])
  @@index([volunteerProfileId])
  @@map("volunteer_shift_signups")
}

model CanvassingScript {
  id             String     @id @default(cuid())
  campaignId     String
  name           String
  scriptType     ScriptType @default(general)
  openingLine    String
  keyMessages    String[]   @default([])
  issueResponses Json?
  closingAsk     String
  literature     String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assignmentTypes     AssignmentType[] @default([])
  literaturePackageId String?

  campaign          Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  literaturePackage LiteraturePackage? @relation(fields: [literaturePackageId], references: [id])
  resourcePackages  AssignmentResourcePackage[]

  @@index([campaignId, scriptType])
  @@map("canvassing_scripts")
}

model MediaMention {
  id          String        @id @default(cuid())
  campaignId  String
  outlet      String
  mentionDate DateTime
  url         String?
  sentiment   SentimentType @default(neutral)
  summary     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, mentionDate])
  @@map("media_mentions")
}

model Coalition {
  id               String    @id @default(cuid())
  campaignId       String
  organizationName String
  contactName      String?
  contactEmail     String?
  memberCount      Int?
  endorsementDate  DateTime?
  isPublic         Boolean   @default(false)
  logoUrl          String?
  memberList       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("coalitions")
}

model OpponentIntel {
  id         String            @id @default(cuid())
  campaignId String
  type       OpponentIntelType
  title      String
  details    String?
  lat        Float?
  lng        Float?
  eventDate  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, type])
  @@map("opponent_intel")
}

model Event {
  id                String          @id @default(cuid())
  campaignId        String
  name              String
  slug              String?
  eventDate         DateTime
  timezone          String          @default("America/Toronto")
  location          String
  address1          String?
  address2          String?
  city              String?
  province          String?
  postalCode        String?
  lat               Float?
  lng               Float?
  capacity          Int?
  maxWaitlist       Int?
  description       String?
  eventType         String?
  status            EventStatus     @default(draft)
  visibility        EventVisibility @default(internal)
  isPublic          Boolean         @default(false)
  allowPublicRsvp   Boolean         @default(false)
  requiresApproval  Boolean         @default(false)
  isVirtual         Boolean         @default(false)
  virtualUrl        String?
  isTownhall        Boolean         @default(false)
  townhallStatus    String?
  townhallRoomUrl   String?
  questionVoting    Boolean         @default(true)
  maxQuestions      Int?            @default(50)
  recurrenceRule    String?
  followUpMessage   String?
  checkInQrSecret   String?
  icalUid           String?
  lastReminderRunAt DateTime?
  publishedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  deletedById       String?

  campaign  Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rsvps     EventRsvp[]
  reminders EventReminder[]
  questions TownhallQuestion[]
  donations Donation[]

  @@index([campaignId, eventDate])
  @@index([campaignId, status])
  @@map("events")
}

model EventRsvp {
  id             String          @id @default(cuid())
  eventId        String
  contactId      String?
  name           String
  email          String
  phone          String?
  status         EventRsvpStatus @default(interested)
  attended       Boolean         @default(false)
  checkedInAt    DateTime?
  checkInCode    String?
  notes          String?
  source         String?
  metadata       Json?
  followUpSentAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([eventId, status])
  @@map("event_rsvps")
}

model EventReminder {
  id           String    @id @default(cuid())
  eventId      String
  channel      String
  templateKey  String?
  scheduledFor DateTime
  sentAt       DateTime?
  status       String    @default("pending")
  errorMessage String?
  createdAt    DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, scheduledFor])
  @@index([status, scheduledFor])
  @@map("event_reminders")
}

model TownhallQuestion {
  id           String    @id @default(cuid())
  eventId      String
  askedByName  String
  askedByEmail String?
  text         String
  upvotes      Int       @default(0)
  isAnswered   Boolean   @default(false)
  isHidden     Boolean   @default(false)
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, upvotes])
  @@map("townhall_questions")
}

model DebugSession {
  id          String      @id @default(cuid())
  userId      String
  title       String?
  status      String      @default("active")
  notes       DebugNote[]
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("debug_sessions")
}

model DebugNote {
  id              String       @id @default(cuid())
  sessionId       String
  session         DebugSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Location
  url             String
  pagePath        String
  elementSelector String?
  elementText     String?
  xPercent        Float?
  yPercent        Float?

  // The note
  type            String
  text            String
  priority        String       @default("medium")

  // Media
  screenshotUrl   String?
  videoUrl        String?

  // Status
  resolved        Boolean      @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?

  createdAt       DateTime     @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, resolved, type])
  @@map("debug_notes")
}

model SocialAccount {
  id                String              @id @default(cuid())
  campaignId        String
  platform          SocialPlatform
  handle            String
  displayName       String?
  externalAccountId String?
  accessTokenEnc    String?
  refreshTokenEnc   String?
  tokenExpiresAt    DateTime?
  status            SocialAccountStatus @default(active)
  metadata          Json?
  lastSyncedAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  posts    SocialPost[]
  mentions SocialMention[]

  @@unique([campaignId, platform, handle])
  @@index([campaignId, platform])
  @@map("social_accounts")
}

model SocialPost {
  id                  String           @id @default(cuid())
  campaignId          String
  socialAccountId     String?
  authorUserId        String?
  title               String?
  content             String
  mediaUrls           String[]         @default([])
  linkUrl             String?
  hashtags            String[]         @default([])
  targetPlatforms     SocialPlatform[] @default([])
  status              SocialPostStatus @default(draft)
  scheduledFor        DateTime?
  publishedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  externalPostId      String?
  approvalRequestedAt DateTime?
  approvedAt          DateTime?
  approvedByUserId    String?
  rejectedAt          DateTime?
  rejectedByUserId    String?
  metrics             Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  author        User?          @relation("SocialPostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  approvedBy    User?          @relation("SocialPostApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy    User?          @relation("SocialPostRejector", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, status])
  @@index([scheduledFor, status])
  @@map("social_posts")
}

model SocialMention {
  id                String                 @id @default(cuid())
  campaignId        String
  socialAccountId   String?
  platform          SocialPlatform
  externalMentionId String
  authorHandle      String?
  authorName        String?
  content           String
  url               String?
  mentionedAt       DateTime
  sentiment         SocialMentionSentiment @default(unknown)
  needsResponse     Boolean                @default(false)
  respondedAt       DateTime?
  assignedToUserId  String?
  resolutionNotes   String?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  assignedTo    User?          @relation("SocialMentionAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@unique([campaignId, platform, externalMentionId])
  @@index([campaignId, mentionedAt])
  @@index([campaignId, needsResponse])
  @@map("social_mentions")
}

model Constituent {
  id              String    @id @default(cuid())
  officialId      String
  campaignId      String?
  contactId       String?
  firstName       String
  lastName        String
  email           String?
  phone           String?
  address1        String?
  address2        String?
  city            String?
  province        String?
  postalCode      String?
  ward            String?
  riding          String?
  tags            String[]  @default([])
  isPriority      Boolean   @default(false)
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  official  Official              @relation(fields: [officialId], references: [id], onDelete: Cascade)
  campaign  Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact   Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  caseFiles ConstituentCaseFile[]

  @@index([officialId, lastName, firstName])
  @@index([campaignId])
  @@index([contactId])
  @@index([postalCode])
  @@map("constituents")
}

model ConstituentCaseFile {
  id                String       @id @default(cuid())
  caseNumber        String?      @unique // auto-generated: WD12-2026-0001
  officialId        String
  constituentId     String
  campaignId        String?
  title             String
  description       String?
  category          String?
  channel           CaseChannel  @default(web)
  priority          CasePriority @default(medium)
  status            CaseStatus   @default(open)
  externalReference String?
  metadata          Json?
  openedAt          DateTime     @default(now())
  dueAt             DateTime?
  resolvedAt        DateTime?
  closedAt          DateTime?
  assignedToUserId  String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  official    Official              @relation(fields: [officialId], references: [id], onDelete: Cascade)
  constituent Constituent           @relation(fields: [constituentId], references: [id], onDelete: Cascade)
  campaign    Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignedTo  User?                 @relation("ConstituentCaseAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  notes       ConstituentCaseNote[]

  @@index([officialId, status])
  @@index([constituentId])
  @@index([assignedToUserId, status])
  @@index([campaignId])
  @@map("constituent_case_files")
}

model ConstituentCaseNote {
  id           String   @id @default(cuid())
  caseFileId   String
  authorUserId String?
  note         String
  isInternal   Boolean  @default(true)
  attachments  String[] @default([])
  createdAt    DateTime @default(now())

  caseFile ConstituentCaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  author   User?               @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([caseFileId, createdAt])
  @@map("constituent_case_notes")
}

model SuperSupporterTask {
  id                String   @id @default(cuid())
  campaignId        String
  contactId         String
  title             String
  status            String   @default("pending")
  contributionNotes String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@map("super_supporter_tasks")
}

model VolunteerExpense {
  id                 String                 @id @default(cuid())
  campaignId         String
  volunteerProfileId String
  amount             Float
  category           String
  receiptUrl         String?
  notes              String?
  status             VolunteerExpenseStatus @default(pending)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  volunteerProfile VolunteerProfile @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@map("volunteer_expenses")
}

model BudgetItem {
  id            String           @id @default(cuid())
  campaignId    String
  itemType      BudgetItemType
  category      String
  amount        Float
  description   String?
  // Enterprise additions (all optional for backward compatibility)
  vendor        String? // who was paid / from whom allocation came
  paymentMethod String? // cash | cheque | credit | e-transfer | invoice
  receiptUrl    String? // Vercel Blob URL to uploaded receipt file
  receiptNumber String? // vendor invoice / receipt number
  status        BudgetItemStatus @default(approved) // pending | approved | paid | rejected | reconciled
  approvedById  String? // user who approved this expense
  paidAt        DateTime? // when the payment actually cleared
  tags          String[]         @default([]) // free-form tags (e.g. "q4", "gotv-push")
  sourceRuleId  String? // if created from a BudgetRule suggestion
  postElection  Boolean          @default(false) // true if incurredAt > campaign election date
  importNotes   String? // freeform notes preserved from imports
  incurredAt    DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  payments BudgetPayment[]

  @@index([campaignId, category])
  @@index([campaignId, status])
  @@index([campaignId, incurredAt])
  @@map("budget_items")
}

// BudgetPayment — individual payment records linked to a parent BudgetItem.
// Real campaign finance files often have a parent expense row with multiple payment details.
model BudgetPayment {
  id               String    @id @default(cuid())
  budgetItemId     String
  amount           Float
  paymentReference String? // e.g. "Cheque #2", "E-transfer 1234"
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime  @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@index([budgetItemId])
  @@map("budget_payments")
}

enum BudgetItemStatus {
  pending
  approved
  paid
  rejected
  reconciled
}

// BudgetRule — rules-driven budgeting config for a campaign.
// Campaigns define rules like "Spend 35% on signs, 20% on digital ads".
// The suggestions API uses these rules + total budget to propose allocations.
model BudgetRule {
  id             String   @id @default(cuid())
  campaignId     String
  category       String // e.g. "Signs", "Digital Ads", "Events"
  percentOfTotal Float? // e.g. 0.35 for 35%
  fixedAmount    Float? // alternative to percent
  priority       Int      @default(1) // 1 = highest
  warnAtPercent  Float    @default(0.85) // warn when spend hits 85% of allocation
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, isActive])
  @@map("budget_rules")
}

// BudgetTemplate — named preset budget distributions for campaigns to apply in one click.
// System seeds defaults like "Municipal (Small)", "Municipal (Large City)", "Federal Riding".
// Custom templates belong to one campaign; system templates have campaignId = null.
// ContactFilterPreset — saved filter combinations for the contacts page.
// Users can save any filter combination with a name for one-click reload.
model ContactFilterPreset {
  id         String   @id @default(cuid())
  campaignId String
  userId     String? // null = campaign-wide preset
  name       String
  filters    Json // { supportLevels, tags, wards, search, followUp, etc. }
  isDefault  Boolean  @default(false) // true = built-in, cannot be deleted
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, userId])
  @@map("contact_filter_presets")
}

model CrmColumnPreference {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  tableKey   String   @default("contacts")
  order      Json
  hidden     Json
  widths     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
