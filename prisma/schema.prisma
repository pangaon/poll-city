  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  createdByUserId String
  updatedByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  campaign    Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("BudgetCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy   User?            @relation("BudgetUpdatedBy", fields: [updatedByUserId], references: [id])
  budgetLines BudgetLine[]
  transfers   BudgetTransfer[]

  @@index([campaignId, status])
  @@map("campaign_budgets")
}

model BudgetLine {
  id                  String                    @id @default(cuid())
  campaignBudgetId    String
  campaignId          String
  parentBudgetLineId  String?
  code                String?
  name                String
  description         String?
  category            FinanceBudgetLineCategory @default(other)
  subcategory         String?
  plannedAmount       Decimal                   @db.Decimal(12, 2) @default(0)
  committedAmount     Decimal                   @db.Decimal(12, 2) @default(0)
  actualAmount        Decimal                   @db.Decimal(12, 2) @default(0)
  warningThresholdPct Float                     @default(0.85)
  ownerUserId         String?
  isActive            Boolean                   @default(true)
  sortOrder           Int                       @default(0)
  isLocked            Boolean                   @default(false)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  campaignBudget   CampaignBudget          @relation(fields: [campaignBudgetId], references: [id], onDelete: Cascade)
  campaign         Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parent           BudgetLine?             @relation("BudgetLineChildren", fields: [parentBudgetLineId], references: [id])
  children         BudgetLine[]            @relation("BudgetLineChildren")
  owner            User?                   @relation("BudgetLineOwner", fields: [ownerUserId], references: [id])
  expenses         FinanceExpense[]
  expenseSplits    FinanceExpenseSplit[]
  purchaseRequests FinancePurchaseRequest[]
  purchaseOrders   FinancePurchaseOrder[]
  reimbursements   FinanceReimbursement[]
  transfersFrom    BudgetTransfer[]        @relation("TransferFrom")
  transfersTo      BudgetTransfer[]        @relation("TransferTo")

  @@index([campaignBudgetId])
  @@index([campaignId, category])
  @@index([parentBudgetLineId])
  @@map("budget_lines")
}

model FinanceVendor {
  id           String            @id @default(cuid())
  campaignId   String?
  vendorType   FinanceVendorType @default(other)
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  website      String?
  paymentTerms String?
  taxNumber    String?
  notes        String?
  isPreferred  Boolean           @default(false)
  isActive     Boolean           @default(true)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  campaign         Campaign?               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  expenses         FinanceExpense[]
  purchaseRequests FinancePurchaseRequest[]
  purchaseOrders   FinancePurchaseOrder[]
  vendorBills      FinanceVendorBill[]

  @@index([campaignId, isActive])
  @@index([vendorType])
  @@map("finance_vendors")
}

model FinanceExpense {
  id                String               @id @default(cuid())
  campaignId        String
  budgetLineId      String?
  vendorId          String?
  purchaseRequestId String?
  purchaseOrderId   String?
  printJobId        String?
  signId            String?
  eventId           String?
  reimbursementId   String?
  amount            Decimal              @db.Decimal(12, 2)
  taxAmount         Decimal              @db.Decimal(12, 2) @default(0)
  currency          String               @default("CAD")
  expenseDate       DateTime
  description       String
  notes             String?
  paymentMethod     FinancePaymentMethod?
  paymentStatus     FinancePaymentStatus @default(unpaid)
  expenseStatus     FinanceExpenseStatus @default(draft)
  sourceType        FinanceSourceType    @default(manual)
  externalReference String?
  receiptAssetId    String?
  invoiceAssetId    String?
  isSplit           Boolean              @default(false)
  isDuplicate       Boolean              @default(false)
  isRecurring       Boolean              @default(false)
  missingReceipt    Boolean              @default(false)
  enteredByUserId   String
  approvedByUserId  String?
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  campaign        Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  budgetLine      BudgetLine?             @relation(fields: [budgetLineId], references: [id])
  vendor          FinanceVendor?          @relation(fields: [vendorId], references: [id])
  purchaseRequest FinancePurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  purchaseOrder   FinancePurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  reimbursement   FinanceReimbursement?   @relation(fields: [reimbursementId], references: [id])
  receiptAsset    FinanceAsset?           @relation("ExpenseReceipt", fields: [receiptAssetId], references: [id])
  invoiceAsset    FinanceAsset?           @relation("ExpenseInvoice", fields: [invoiceAssetId], references: [id])
  enteredBy       User                    @relation("ExpenseEnteredBy", fields: [enteredByUserId], references: [id])
  approvedBy      User?                   @relation("ExpenseApprovedBy", fields: [approvedByUserId], references: [id])
  splitLines      FinanceExpenseSplit[]

  @@index([campaignId, expenseDate])
  @@index([campaignId, expenseStatus])
  @@index([campaignId, budgetLineId])
  @@index([vendorId])
  @@map("finance_expenses")
}

model FinanceExpenseSplit {
  id           String     @id @default(cuid())
  expenseId    String
  budgetLineId String
  amount       Decimal    @db.Decimal(12, 2)
