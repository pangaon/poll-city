// ─────────────────────────────────────────────────────────────────────────────
// CIVIC DATA INGESTION — SOURCE REGISTRY
// Foundation for official Canadian civic/political data pipeline.
// Phase 1 connectors: Toronto Open Data, Elections Canada, Elections Ontario,
// Statistics Canada. Full multi-city ingestion platform builds on top of this.
// ─────────────────────────────────────────────────────────────────────────────

/// Official data source registry — one row per government/agency source
model DataSource {
  id                   String    @id @default(cuid())
  name                 String    // "Toronto Open Data", "Elections Canada", "Statistics Canada"
  slug                 String    @unique // "toronto-open-data", "elections-canada"
  jurisdictionLevel    String    // "municipal" | "provincial" | "federal" | "statistical"
  jurisdictionName     String    // "Toronto", "Ontario", "Canada"
  sourceType           String    // "api" | "bulk_download" | "rss" | "manual_import"
  platformType         String    // "ckan" | "arcgis" | "statscan_wds" | "custom" | "unknown"
  baseUrl              String
  licenseUrl           String?
  commercialUseAllowed Boolean   @default(true)
  authRequired         Boolean   @default(false)
  isActive             Boolean   @default(true)
  refreshStrategy      String    @default("scheduled") // "scheduled" | "manual" | "webhook"
  ownerTeam            String    @default("platform") // who owns this ingestion
  notes                String?   @db.Text
  lastCheckedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  datasets     Dataset[]
  ingestRuns   IngestRun[]
  geoDistricts GeoDistrict[]

  @@index([jurisdictionLevel])
  @@index([isActive])
  @@map("data_sources")
}

/// Individual dataset/endpoint within a DataSource
model Dataset {
  id                       String    @id @default(cuid())
  dataSourceId             String
  name                     String    // "Ward Boundaries 2022", "311 Service Requests"
  slug                     String    // "toronto-ward-boundaries", "toronto-311"
  category                 String    // "boundaries" | "elections" | "demographics" | "issues" | "finance" | "planning"
  description              String?   @db.Text
  officialDatasetUrl       String?
  apiEndpointUrl           String?
  downloadUrl              String?
  format                   String    // "json" | "csv" | "geojson" | "shp" | "zip" | "xml"
  isSpatial                Boolean   @default(false)
  containsPii              Boolean   @default(false)
  status                   String    @default("planned") // "planned" | "active" | "paused" | "deprecated" | "broken"
  updateFrequencyDeclared  String?   // "daily" | "weekly" | "monthly" | "annual" | "on_election"
  refreshIntervalMinutes   Int       @default(10080) // default: weekly
  lastIngestedAt           DateTime?
  lastSeenModifiedAt       DateTime?
  recordCount              Int?
  schemaHash               String?   // hash of the last seen schema for drift detection
  qualityScore             Float?    // 0-100 computed quality score
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  dataSource   DataSource  @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  ingestRuns   IngestRun[]
  geoDistricts GeoDistrict[]

  @@unique([dataSourceId, slug])
  @@index([category])
  @@index([status])
  @@index([dataSourceId])
  @@map("datasets")
}

/// Audit log for every ingestion attempt — raw zone record
model IngestRun {
  id              String    @id @default(cuid())
  dataSourceId    String
  datasetId       String
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @default("running") // "running" | "success" | "partial" | "failed" | "skipped"
  httpStatus      Int?
  recordsFetched  Int?
  recordsInserted Int?
  recordsUpdated  Int?
  recordsFailed   Int?
  payloadChecksum String?   // SHA-256 of raw payload for deduplication
  errorSummary    String?   @db.Text
  rawStorageUri   String?   // path to raw payload if stored externally
  triggeredBy     String    @default("cron") // "cron" | "manual" | "webhook"
  durationMs      Int?

  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  dataset    Dataset    @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, startedAt])
  @@index([status])
  @@index([dataSourceId, completedAt])
  @@map("ingest_runs")
}

/// QA annotation — George clicks any element on any page to attach a note
model QaAnnotation {
  id               String    @id @default(cuid())
  pagePath         String    // e.g. "/volunteers", "/events/abc123"
  posX             Float     // 0–1 fraction of viewport width at time of click
  posY             Float     // 0–1 fraction of viewport height at time of click
  elementSelector  String?   // best-effort CSS selector of clicked element
  elementText      String?   @db.Text // text content of clicked element (first 200 chars)
  issueType        String    // "bug"|"ux"|"copy"|"design"|"missing"|"broken"|"question"|"positive"
  severity         String    @default("medium") // "critical"|"high"|"medium"|"low"|"note"
  notes            String?   @db.Text
  status           String    @default("open") // "open"|"in_progress"|"fixed"|"wont_fix"
  createdByUserId  String
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy User @relation("QaAnnotationCreator", fields: [createdByUserId], references: [id])

  @@index([pagePath, status])
  @@index([status, createdAt])
  @@index([severity])
  @@map("qa_annotations")
}

/// Links any entity (contact, official, campaign) to a canonical boundary
/// Replaces ad-hoc ward/riding string fields with FK-linked boundary memberships
model BoundaryMembership {
  id              String      @id @default(cuid())
  entityType      String      // "contact" | "official" | "campaign" | "user"
  entityId        String
  geoBoundaryId   String
  method          String      @default("postal_map") // "postal_map" | "point_in_polygon" | "source_native" | "manual"
  confidenceScore Float       @default(1.0)
  createdAt       DateTime    @default(now())

  geoBoundary GeoDistrict @relation(fields: [geoBoundaryId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([geoBoundaryId])
  @@index([entityType, entityId, geoBoundaryId])
  @@map("boundary_memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// ELECTION DAY — SCRUTINEER ASSIGNMENTS
// ─────────────────────────────────────────────────────────────────────────────

/// Assigns a campaign volunteer as a scrutineer (official poll watcher) to a
/// specific polling station. The candidate must authorize each appointment.
/// Once signed, the scrutineer's device is pre-populated with their assigned
/// station so OCR scans auto-tag the source without manual data entry.
model ScrutineerAssignment {
  id              String    @id @default(cuid())
  campaignId      String
  userId          String    // the scrutineer
  pollingStation  String    // "Polling Station 23 — Ward 5"
  pollingAddress  String?
  municipality    String
  ward            String?
  province        String    @default("ON")
  electionDate    DateTime
  assignedBy      String    // userId of the manager who created the assignment
  // Candidate authorization
  candidateSigned Boolean   @default(false)
  signedAt        DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user           User      @relation("ScrutineerUser", fields: [userId], references: [id])
  assignedByUser User      @relation("ScrutineerAssigner", fields: [assignedBy], references: [id])

  @@unique([campaignId, userId, electionDate, pollingStation])
  @@index([campaignId])
  @@index([campaignId, electionDate])
  @@map("scrutineer_assignments")
}

// ─────────────────────────────────────────────────────────────────────────────
// UNIFIED FIELD OPERATIONS ENGINE v1
// ─────────────────────────────────────────────────────────────────────────────

enum AssignmentType {
  canvass
  lit_drop
  sign_install
  sign_remove
}

enum AssignmentStatus {
  draft
  published
  assigned
  in_progress
  completed
  cancelled
  reassigned
}

enum StopStatus {
  pending
  completed
  skipped
  exception
  not_home
  no_access
}

enum ExceptionType {
  aggressive_resident
  no_access
  gated_property
  wrong_address
  sign_already_removed
  sign_damaged
  sign_missing
  weather
  other
}

enum SignCondition {
  new
  good
  fair
  damaged
  retired
}

enum LiteraturePieceType {
  flyer
  door_hanger
  palm_card
  mailer_postcard
  lawn_sign_rider
  push_card
}

// ─────────────────────────────────────────────────────────────────────────────
// LITERATURE
// ─────────────────────────────────────────────────────────────────────────────

model LiteraturePiece {
  id              String              @id @default(cuid())
  campaignId      String
  name            String
  pieceType       LiteraturePieceType
  version         String              @default("v1")
  description     String?
  printUrl        String?
  quantityInStock Int                 @default(0)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  campaign              Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  literaturePackageItems LiteraturePackageItem[]

  @@index([campaignId, isActive])
  @@map("literature_pieces")
}

model LiteraturePackage {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign         Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  items            LiteraturePackageItem[]
  canvassingScripts CanvassingScript[]
  resourcePackages AssignmentResourcePackage[]

  @@index([campaignId, isActive])
  @@map("literature_packages")
}

model LiteraturePackageItem {
  id                  String   @id @default(cuid())
  packageId           String
  literaturePieceId   String
  quantityPerStop     Int      @default(1)
  createdAt           DateTime @default(now())

  package        LiteraturePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  literaturePiece LiteraturePiece  @relation(fields: [literaturePieceId], references: [id], onDelete: Cascade)

  @@unique([packageId, literaturePieceId])
  @@index([packageId])
  @@map("literature_package_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// SIGN INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model SignInventoryItem {
  id               String        @id @default(cuid())
  campaignId       String
  signType         String        // standard | large | window | road | banner
  totalQuantity    Int           @default(0)
  deployedQuantity Int           @default(0)
  storageLocation  String?
  condition        SignCondition @default(good)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  campaign         Campaign                    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  resourcePackages AssignmentResourcePackage[]

  @@index([campaignId])
  @@map("sign_inventory_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// FIELD ASSIGNMENT
// ─────────────────────────────────────────────────────────────────────────────

model FieldAssignment {
  id                 String           @id @default(cuid())
  campaignId         String
  assignmentType     AssignmentType
  name               String
  description        String?
  status             AssignmentStatus @default(draft)
  fieldUnitId        String?          // FK to Turf (geography — optional override)
  targetWard         String?          // Primary targeting: ward name
  targetPolls        String[]         @default([]) // Specific poll numbers within the ward; empty = whole ward
  assignedUserId     String?
  assignedVolunteerId String?
  assignedGroupId    String?
  scheduledDate      DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  printPacketUrl     String?
  createdById        String
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  campaign          Campaign                   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fieldUnit         Turf?                      @relation(fields: [fieldUnitId], references: [id])
  assignedUser      User?                      @relation("FieldAssignmentAssignee", fields: [assignedUserId], references: [id])
  assignedVolunteer VolunteerProfile?          @relation("FieldAssignmentVolunteer", fields: [assignedVolunteerId], references: [id])
  assignedGroup     VolunteerGroup?            @relation("FieldAssignmentGroup", fields: [assignedGroupId], references: [id])
  createdBy         User                       @relation("FieldAssignmentCreator", fields: [createdById], references: [id])
  stops             AssignmentStop[]
  resourcePackage   AssignmentResourcePackage?

  @@index([campaignId, assignmentType])
  @@index([campaignId, status])
  @@index([assignedUserId])
  @@index([assignedGroupId])
  @@map("field_assignments")
}

model AssignmentStop {
  id              String         @id @default(cuid())
  assignmentId    String
  contactId       String?
  householdId     String?
  signId          String?
  order           Int
  status          StopStatus     @default(pending)
  outcome         Json?          // type-specific — validated by Zod at API layer
  exceptionType   ExceptionType?
  exceptionNotes  String?
  completedAt     DateTime?
  completedById   String?
  notes           String?
  createdAt       DateTime       @default(now())

  assignment    FieldAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  contact       Contact?        @relation(fields: [contactId], references: [id])
  household     Household?      @relation(fields: [householdId], references: [id])
  sign          Sign?           @relation(fields: [signId], references: [id])
  completedBy   User?           @relation("StopCompleter", fields: [completedById], references: [id])

  @@unique([assignmentId, order])
  @@index([assignmentId])
  @@index([assignmentId, status])
  @@map("assignment_stops")
}

model AssignmentResourcePackage {
  id                    String   @id @default(cuid())
  assignmentId          String   @unique
  scriptPackageId       String?
  literaturePackageId   String?
  plannedLiteratureQty  Int?
  actualLiteratureQty   Int?
  signInventoryItemId   String?
  signsAllocated        Int?
  signsInstalled        Int?
  signsRecovered        Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignment          FieldAssignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scriptPackage       CanvassingScript?  @relation(fields: [scriptPackageId], references: [id])
  literaturePackage   LiteraturePackage? @relation(fields: [literaturePackageId], references: [id])
  signInventoryItem   SignInventoryItem? @relation(fields: [signInventoryItemId], references: [id])

  @@map("assignment_resource_packages")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRINT INVENTORY SYSTEM
// Unified inventory tracking for all printed campaign materials.
// PrintOrder fulfilled → creates PrintInventory record.
// Every qty change goes through PrintInventoryLog — no direct mutations.
// ─────────────────────────────────────────────────────────────────────────────

model PrintInventory {
  id                String           @id @default(cuid())
  campaignId        String
  sku               String
  productType       PrintProductType
  description       String?
  orderId           String?          @unique  // source PrintOrder when fulfilled
  totalQty          Int              @default(0)  // set at receive time, never decreases
  availableQty      Int              @default(0)  // totalQty - reservedQty - depletedQty - wastedQty
  reservedQty       Int              @default(0)  // assigned to packs/volunteers, not yet used
  depletedQty       Int              @default(0)  // confirmed used/distributed
  wastedQty         Int              @default(0)  // damaged / discarded
  location          String           @default("hq")  // hq | storage | event | in_field
  reorderThreshold  Int?
  notes             String?
  receivedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign  Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order     PrintOrder?          @relation(fields: [orderId], references: [id])
  logs      PrintInventoryLog[]
  packItems PrintPackItem[]

  @@unique([campaignId, sku])
  @@index([campaignId, productType])
  @@map("print_inventory")
}

// Audit log — one row per quantity change event.
// NEVER update PrintInventory qty fields directly — always via a log entry.
model PrintInventoryLog {
  id            String   @id @default(cuid())
  inventoryId   String
  campaignId    String
  action        String   // received | assigned | returned | depleted | wasted | adjusted
  qty           Int      // positive = stock increase, negative = stock decrease
  balance       Int      // availableQty AFTER this action
  notes         String?
  referenceId   String?  // packId | fieldAssignmentId | orderId | etc.
  referenceType String?  // pack | field_assignment | order | manual
  userId        String?
  createdAt     DateTime @default(now())

  inventory PrintInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id])

  @@index([inventoryId])
  @@index([campaignId, createdAt])
  @@map("print_inventory_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRINT PACKS
// Auto-generated material bundles for field operations.
// Generated from turf/poll data. Linked to FieldAssignments.
// ─────────────────────────────────────────────────────────────────────────────

model PrintPack {
  id                  String   @id @default(cuid())
  campaignId          String
  name                String
  packType            String   // walk_kit | sign_install_kit | lit_drop_kit | event_kit | gotv_kit
  targetCount         Int      @default(0)   // households/stops/doors in target area
  bufferPct           Float    @default(0.20) // 20% default buffer
  turfId              String?
  pollNumber          String?
  fieldAssignmentId   String?
  eventId             String?
  status              String   @default("draft") // draft | fulfilled | distributed | returned
  notes               String?
  generatedAt         DateTime?
  distributedAt       DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  items    PrintPackItem[]

  @@index([campaignId, packType])
  @@index([campaignId, fieldAssignmentId])
  @@map("print_packs")
}

model PrintPackItem {
  id           String   @id @default(cuid())
  packId       String
  inventoryId  String?  // null until inventory is assigned
  productType  PrintProductType
  requiredQty  Int              // calculated required quantity
  fulfilledQty Int      @default(0)  // actually pulled from inventory
  notes        String?

  pack      PrintPack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  inventory PrintInventory? @relation(fields: [inventoryId], references: [id])

  @@index([packId])
  @@map("print_pack_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// FINANCIAL OPERATIONS SUITE
// Phase 1: Financial Domain Model
// ─────────────────────────────────────────────────────────────────────────────

model CampaignBudget {
  id              String              @id @default(cuid())
  campaignId      String
  name            String
  electionCycle   String?
