// ─────────────────────────────────────────────────────────────────────────────
// FUNDRAISING SUITE — FULL DOMAIN MODEL
// ─────────────────────────────────────────────────────────────────────────────

// ── Enums ────────────────────────────────────────────────────────────────────

enum DonationStatus {
  pledged   // captured at door/phone, not yet processed
  processing // payment in flight (Stripe pending)
  processed  // payment received and confirmed
  receipted  // official receipt issued
  failed     // payment failed
  cancelled
  refunded
  partially_refunded
}

enum DonationType {
  one_time
  recurring
  pledge
  in_kind
  event
  tribute   // memorial / in-honour-of
}

enum DonationPaymentMethod {
  stripe_card
  stripe_ach
  cash
  cheque
  e_transfer
  wire_transfer
  in_kind
  other
}

enum DonationComplianceStatus {
  pending   // not yet evaluated
  approved  // manually approved or auto-passed
  flagged   // needs review
  over_limit
  blocked   // rejected by compliance
  exempted  // override with documented reason
}

enum ReceiptStatus {
  pending
  generated
  sent
  resent
  failed
  void
}

enum DonorStatus {
  prospect
  first_time
  repeat
  lapsed    // no donation in 365+ days
  major     // lifetime giving >= threshold
  recurring
  champion  // major + recurring + event donor
}

enum DonorTier {
  general
  silver
  gold
  platinum
  major
}

enum FundraisingCampaignStatus {
  draft
  active
  paused
  completed
  archived
}

enum DonationSourceType {
  online_page
  canvass
  event
  direct_mail
  phone_bank
  import
  referral
  other
}

enum DonationPageStatus {
  draft
  active
  paused
  archived
}

enum RecurrenceFrequency {
  weekly
  biweekly
  monthly
  quarterly
  annually
}

enum RecurrenceStatus {
  active
  paused
  cancelled
  completed
  failed
}

enum PledgeStatus {
  pending
  partial
  fulfilled
  overdue
  cancelled
}

enum RefundStatus {
  pending
  approved
  processing
  processed
  failed
  rejected
}

enum ReconciliationStatus {
  pending
  matched
  unmatched
  partial
  disputed
}

// ── Donation (expanded from canvass-pledge stub) ──────────────────────────────

model Donation {
  id                    String                   @id @default(cuid())
  campaignId            String
  contactId             String?
  recordedById          String                   // user who captured it
  approvedByUserId      String?

  // Core financials
  amount                Float
  feeAmount             Float                    @default(0)  // processor fee
  netAmount             Float                    @default(0)  // amount - feeAmount
  currency              String                   @default("CAD")
  refundedAmount        Float                    @default(0)

  // Classification
  donationType          DonationType             @default(one_time)
  status                DonationStatus           @default(pledged)
  paymentMethod         DonationPaymentMethod?
  method                String?                  // legacy string field (kept for backward compat)
  isRecurring           Boolean                  @default(false)

  // Compliance + receipt
  complianceStatus      DonationComplianceStatus @default(pending)
  receiptStatus         ReceiptStatus            @default(pending)

  // Relations to fundraising objects
  fundraisingCampaignId String?
  eventId               String?
  sourceId              String?
  pageId                String?
  recurrencePlanId      String?

  // Payment gateway
  paymentIntentId       String?                  // Stripe PaymentIntent ID
  externalTransactionId String?                  // cheque#, e-transfer ref, etc.

  // Content
  notes                 String?
  dedicationName        String?                  // "In memory of..." / "In honour of..."
  dedicationType        String?                  // "memory" | "honour"
  isAnonymous           Boolean                  @default(false)
  metadataJson          Json?                    // raw gateway response, UTM params, etc.

  // Timestamps
  donationDate          DateTime                 @default(now())
  collectedAt           DateTime                 @default(now())  // legacy alias
  processedAt           DateTime?
  receiptNumber         String?                  // legacy field — superseded by DonationReceipt

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  deletedById           String?

  // Relations
  campaign             Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact              Contact?             @relation(fields: [contactId], references: [id])
  recordedBy           User                 @relation("RecordedDonations", fields: [recordedById], references: [id])
  approvedBy           User?                @relation("ApprovedDonations", fields: [approvedByUserId], references: [id])
  fundraisingCampaign  FundraisingCampaign? @relation(fields: [fundraisingCampaignId], references: [id])
  event                Event?               @relation(fields: [eventId], references: [id])
  source               DonationSource?      @relation(fields: [sourceId], references: [id])
  page                 DonationPage?        @relation(fields: [pageId], references: [id])
  recurrencePlan       RecurrencePlan?      @relation(fields: [recurrencePlanId], references: [id])
  receipt              DonationReceipt?
  refunds              Refund[]
  reconciliations      PaymentReconciliation[]

  @@index([campaignId])
  @@index([campaignId, donationDate])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([paymentIntentId])
  @@map("donations")
}

// ── FundraisingCampaign — named fundraising initiative ────────────────────────

model FundraisingCampaign {
  id              String                    @id @default(cuid())
  campaignId      String
  name            String
  description     String?
  goalAmount      Float?
  raisedAmount    Float                     @default(0)
  donorCount      Int                       @default(0)
  startDate       DateTime
  endDate         DateTime?
  status          FundraisingCampaignStatus @default(draft)
  defaultCurrency String                    @default("CAD")
  createdByUserId String
  updatedByUserId String?
  deletedAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("FundraisingCampaignCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy     User?          @relation("FundraisingCampaignUpdatedBy", fields: [updatedByUserId], references: [id])
  donations     Donation[]
  donationPages DonationPage[]
  pledges       Pledge[]

  @@index([campaignId])
  @@map("fundraising_campaigns")
}

// ── DonorProfile — enriched donor intelligence record ────────────────────────

model DonorProfile {
  id                String      @id @default(cuid())
  campaignId        String
  contactId         String      @unique
  donorStatus       DonorStatus @default(first_time)
  donorTier         DonorTier   @default(general)
  lifetimeGiving    Float       @default(0)
  firstDonationDate DateTime?
  lastDonationDate  DateTime?
  largestDonation   Float?
  donationCount     Int         @default(0)
  recurringDonor    Boolean     @default(false)
  notes             String?
  riskFlagsJson     Json?       // [{flag: "corporate_keyword", detectedAt: "...", clearedAt: null}]
  metadataJson      Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([campaignId, donorStatus])
  @@index([campaignId, lifetimeGiving])
  @@map("donor_profiles")
}

// ── DonationSource — UTM / channel tracking ───────────────────────────────────

model DonationSource {
  id             String             @id @default(cuid())
  campaignId     String
  name           String
  sourceType     DonationSourceType @default(other)
  medium         String?            // email | sms | social | direct | qr
  campaignCode   String?            // UTM campaign code
  channel        String?            // utm_channel override
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([campaignId])
  @@map("donation_sources")
}

// ── DonationPage — hosted / embedded donation pages ──────────────────────────

model DonationPage {
  id                    String             @id @default(cuid())
  campaignId            String
  fundraisingCampaignId String?
  slug                  String
  title                 String
  description           String?
  suggestedAmountsJson  Json               @default("[25,50,100,250]")
  minimumAmount         Float?             @default(5)
  pageStatus            DonationPageStatus @default(draft)
  themeConfigJson       Json?
  thankYouMessage       String?
  showGoalThermometer   Boolean            @default(false)
  allowRecurring        Boolean            @default(true)
  requirePhone          Boolean            @default(false)
  requireEmployer       Boolean            @default(false)
  active                Boolean            @default(true)
  publishedAt           DateTime?
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fundraisingCampaign FundraisingCampaign? @relation(fields: [fundraisingCampaignId], references: [id])
  donations           Donation[]
  recurrencePlans     RecurrencePlan[]

  @@unique([campaignId, slug])
  @@index([campaignId])
  @@map("donation_pages")
}

// ── RecurrencePlan — recurring donation subscriptions ────────────────────────

model RecurrencePlan {
  id                     String            @id @default(cuid())
  campaignId             String
  contactId              String?
  donationPageId         String?
  frequency              RecurrenceFrequency @default(monthly)
  amount                 Float
  currency               String            @default("CAD")
  startDate              DateTime
  endDate                DateTime?
  nextChargeDate         DateTime?
  status                 RecurrenceStatus  @default(active)
  externalSubscriptionId String?           // Stripe Subscription ID
  failureCount           Int               @default(0)
  lastChargedAt          DateTime?
  lastFailedAt           DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact?      @relation(fields: [contactId], references: [id])
  donationPage DonationPage? @relation(fields: [donationPageId], references: [id])
  donations    Donation[]

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([externalSubscriptionId])
  @@map("recurrence_plans")
}

// ── Pledge — commitment to donate (fulfilled over time) ───────────────────────

model Pledge {
  id                    String      @id @default(cuid())
  campaignId            String
  contactId             String?
  fundraisingCampaignId String?
  pledgedAmount         Float
  fulfilledAmount       Float       @default(0)
  pledgeDate            DateTime    @default(now())
  dueDate               DateTime?
  status                PledgeStatus @default(pending)
  notes                 String?
  reminderSentAt        DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact             Contact?             @relation(fields: [contactId], references: [id])
  fundraisingCampaign FundraisingCampaign? @relation(fields: [fundraisingCampaignId], references: [id])

  @@index([campaignId])
  @@index([campaignId, status])
  @@map("pledges")
}

// ── Refund — refund records (partial or full) ─────────────────────────────────

model Refund {
  id                String       @id @default(cuid())
  campaignId        String
  donationId        String
  refundAmount      Float
  refundReason      String
  refundDate        DateTime     @default(now())
  externalRefundId  String?      // Stripe refund ID
  status            RefundStatus @default(pending)
  processedByUserId String?
  approvedByUserId  String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation    Donation @relation(fields: [donationId], references: [id])
  processedBy User?    @relation("RefundProcessedBy", fields: [processedByUserId], references: [id])
  approvedBy  User?    @relation("RefundApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([campaignId])
  @@index([donationId])
  @@map("refunds")
}

// ── DonationReceipt — official receipt tracking ───────────────────────────────

model DonationReceipt {
  id            String        @id @default(cuid())
  campaignId    String
  donationId    String        @unique
  receiptNumber String
  issuedDate    DateTime?
  receiptStatus ReceiptStatus @default(pending)
  assetUrl      String?       // S3 / Cloudinary URL of PDF
  sentAt        DateTime?
  resentAt      DateTime?
  sentByUserId  String?
  failureReason String?
  voidedAt      DateTime?
  voidedReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation  Donation  @relation(fields: [donationId], references: [id])
  sentBy    User?     @relation("ReceiptSentBy", fields: [sentByUserId], references: [id])

  @@index([campaignId])
  @@index([campaignId, receiptStatus])
  @@map("donation_receipts")
}

// ── PaymentReconciliation — gateway settlement matching ───────────────────────

model PaymentReconciliation {
  id                   String               @id @default(cuid())
  campaignId           String
  donationId           String?
  externalBatchId      String?              // Stripe payout ID / bank batch ref
  gateway              String               @default("stripe")
  settlementDate       DateTime?
  settlementAmount     Float?
  reconciledAt         DateTime?
  reconciledByUserId   String?
  reconciliationStatus ReconciliationStatus @default(pending)
  notes                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation      Donation? @relation(fields: [donationId], references: [id])
  reconciledBy  User?     @relation("ReconciliationReconciledBy", fields: [reconciledByUserId], references: [id])

  @@index([campaignId])
  @@index([campaignId, reconciliationStatus])
  @@index([externalBatchId])
  @@map("payment_reconciliations")
}

// ── DonorAuditLog — immutable audit trail for sensitive donor/donation changes ──

model DonorAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  entityType   String   // "Donation" | "DonorProfile" | "Refund" | "RecurrencePlan" | "Pledge"
