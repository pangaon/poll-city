}

model FinanceVendorBill {
  id              String                  @id @default(cuid())
  campaignId      String
  vendorId        String?
  purchaseOrderId String?
  billNumber      String?
  amount          Decimal                 @db.Decimal(12, 2)
  taxAmount       Decimal                 @db.Decimal(12, 2) @default(0)
  currency        String                  @default("CAD")
  dueDate         DateTime?
  receivedDate    DateTime                @default(now())
  paidDate        DateTime?
  status          FinanceVendorBillStatus @default(received)
  notes           String?
  assetId         String?
  deletedAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  campaign      Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  vendor        FinanceVendor?        @relation(fields: [vendorId], references: [id])
  purchaseOrder FinancePurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  asset         FinanceAsset?         @relation(fields: [assetId], references: [id])

  @@index([campaignId, status])
  @@index([vendorId])
  @@map("finance_vendor_bills")
}

model FinanceReimbursement {
  id              String                     @id @default(cuid())
