  @@map("volunteer_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// POLLING ENGINE (shared — used by both apps)
// ─────────────────────────────────────────────────────────────────────────────

model Poll {
  id                   String         @id @default(cuid())
  question             String
  description          String?
  type                 PollType       @default(binary)
  visibility           PollVisibility @default(public)
  // Geographic targeting
  targetRegion         String? // ward, riding, province, or "national"
  targetPostalPrefixes String[]       @default([])
  // Attribution
  campaignId           String?
  officialId           String?
  createdByUserId      String?
  // Options (for multiple_choice / ranked)
  options              PollOption[]
  responses            PollResponse[]
  // Timing
  startsAt             DateTime       @default(now())
  endsAt               DateTime?
  // Metadata
  totalResponses       Int            @default(0)
  isActive             Boolean        @default(true)
  isFeatured           Boolean        @default(false)
  tags                 String[]       @default([])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  campaign         Campaign?        @relation(fields: [campaignId], references: [id])
  official         Official?        @relation(fields: [officialId], references: [id])
  wordCloudEntries WordCloudEntry[]

  @@index([targetRegion])
  @@index([isActive, isFeatured])
  @@map("polls")
}

model PollOption {
  id        String         @id @default(cuid())
  pollId    String
  text      String
  order     Int            @default(0)
  responses PollResponse[]

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@map("poll_options")
}

model PollResponse {
  id          String   @id @default(cuid())
  pollId      String
  // ANONYMOUS POLLING: userId is kept for backward compatibility but new responses
  // use voteHash (SHA-256 of pollId + voterId + secret salt) for duplicate prevention.
  // userId is NOT used to trace votes — only voteHash is checked.
  userId      String? // DEPRECATED — kept for legacy data; new responses store null or hash only
  optionId    String? // for multiple choice / ranked
  value       String? // for binary (yes/no/left/right) or slider (0-100)
  rank        Int? // for ranked polls
  // Anonymous vote hash: SHA-256(pollId + identifier + POLL_ANONYMITY_SALT)
  // Cannot be reversed to find the voter. Prevents double-voting.
  voteHash    String?  @unique
  // Voter receipt: SHA-256(pollId + optionId/value + random nonce)
  // Given to voter after voting so they can verify their vote was counted.
  receiptHash String?  @unique
  // Geo snapshot — aggregate only, never linked to identity
  postalCode  String?
  ward        String?
  riding      String?
  // Rate limiting only — NOT stored for identity. Hashed before storage.
  ipHash      String?
  createdAt   DateTime @default(now())

  poll   Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption? @relation(fields: [optionId], references: [id])
  user   User?       @relation(fields: [userId], references: [id])

  @@index([pollId])
  @@index([postalCode])
  @@index([voteHash])
  @@map("poll_responses")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPORT SIGNALS (Poll City Social)
