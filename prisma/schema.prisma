  low     // 40-59: possible match — manual scan only
}

enum DuplicateDecision {
  pending
  merged
  not_duplicate
  deferred
  auto_linked
}

// ─────────────────────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  role                 Role      @default(VOLUNTEER)
  avatarUrl            String?
  phone                String?
  // Multi-campaign: which campaign this user is currently viewing
  // Set on login and updated via /api/campaigns/switch
  activeCampaignId     String?
  // Geo fields for Social users
  postalCode           String?
  address              String?
  ward                 String?
  riding               String?
  geoLat               Float?
  geoLng               Float?
  // Social preferences
  emailVerified        Boolean   @default(false)
  pushEnabled          Boolean   @default(true)
  notifyElections      Boolean   @default(true)
  notifyPolls          Boolean   @default(true)
  isActive             Boolean   @default(true)
  lastLoginAt          DateTime?
  // Password reset
  passwordResetToken   String?   @unique
  passwordResetExpiry  DateTime?
  // Account lockout
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  // Session invalidation nonce (increment to revoke active JWT sessions)
  sessionVersion       Int       @default(0)
  // Two-factor authentication (TOTP)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  twoFactorVerifiedAt  DateTime?
  // Email OTP
  emailOtpCode         String?
  emailOtpExpiry       DateTime?
  emailOtpAttempts     Int       @default(0)
  // SMS OTP
  smsOtpCode           String?
  smsOtpExpiry         DateTime?
  smsOtpAttempts       Int       @default(0)
  // WebAuthn (Face ID, Touch ID, Windows Hello)
  webauthnCredentials  Json      @default("[]")
  // Security preferences
  preferredMfaMethod   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Campaign side
  memberships          Membership[]
  interactions         Interaction[]
  tasksAssigned        Task[]                   @relation("AssignedTasks")
  tasksCreated         Task[]                   @relation("CreatedTasks")
  activityLogs         ActivityLog[]
  canvassAssignments   CanvassAssignment[]
  volunteerProfile     VolunteerProfile?
  donationsRecorded    Donation[]               @relation("RecordedDonations")
  gotvBatchesUploaded  GotvBatch[]              @relation("UploadedGotvBatches")
  subscription         Subscription?
  importLogs           ImportLog[]
  crmColumnPreferences CrmColumnPreference[]
  importTemplates      CampaignImportTemplate[]
  uploadedDocuments    CampaignDocument[]       @relation("UserUploadedDocuments")

  // Turf canvassing
  turfAssignments   Turf[]             @relation("TurfAssignee")
  canvasserLocation CanvasserLocation?

  // Social side
  pollResponses         PollResponse[]
  supportSignals        SupportSignal[]
  officialFollows       OfficialFollow[]
  questions             PublicQuestion[]
  notifications         Notification[]
  consentLogs           ConsentLog[]
  pushSubscriptions     PushSubscription[]
  notificationLogs      NotificationLog[]
  socialPostsAuthored   SocialPost[]          @relation("SocialPostAuthor")
  socialPostsApproved   SocialPost[]          @relation("SocialPostApprover")
  socialPostsRejected   SocialPost[]          @relation("SocialPostRejector")
  socialMentionsOwned   SocialMention[]       @relation("SocialMentionAssignee")
  constituentCasesOwned ConstituentCaseFile[] @relation("ConstituentCaseAssignee")
  constituentCaseNotes  ConstituentCaseNote[]
  volunteerLocations      VolunteerLocation[]
  voiceBroadcastsCreated  VoiceBroadcast[]     @relation("VoiceBroadcastCreator")
  phoneBankSessions       PhoneBankSession[]   @relation("PhoneBankVolunteer")
  debugSessions            DebugSession[]
  newsletterCampaignsAuthored NewsletterCampaign[] @relation("NewsletterAuthor")
  scrutineerAssignments       ScrutineerAssignment[] @relation("ScrutineerUser")
  scrutineerAssignedBy        ScrutineerAssignment[] @relation("ScrutineerAssigner")
  printInventoryLogs          PrintInventoryLog[]

  // Field operations
  fieldAssignmentsAssigned    FieldAssignment[]      @relation("FieldAssignmentAssignee")
  fieldAssignmentsCreated     FieldAssignment[]      @relation("FieldAssignmentCreator")
  assignmentStopsCompleted    AssignmentStop[]       @relation("StopCompleter")
  signAssignments             Sign[]                 @relation("SignAssignee")

  // Civic social
  civicProfile   CivicProfile?    @relation("UserCivicProfile")
  voterPassport  VoterPassport?   @relation("UserVoterPassport")
  civicCredits   CivicCredit[]    @relation("UserCivicCredits")
  qaAnnotations  QaAnnotation[]   @relation("QaAnnotationCreator")

  // Fundraising Suite
  donationsApproved          Donation[]               @relation("ApprovedDonations")
  fundraisingCampaignsCreated FundraisingCampaign[]  @relation("FundraisingCampaignCreatedBy")
  fundraisingCampaignsUpdated FundraisingCampaign[]  @relation("FundraisingCampaignUpdatedBy")
  refundsProcessed           Refund[]                 @relation("RefundProcessedBy")
  refundsApproved            Refund[]                 @relation("RefundApprovedBy")
  receiptsIssued             DonationReceipt[]        @relation("ReceiptSentBy")
  reconciliationsProcessed   PaymentReconciliation[]  @relation("ReconciliationReconciledBy")
  donorAuditActed            DonorAuditLog[]          @relation("DonorAuditActor")

  // Finance
  budgetsCreated             CampaignBudget[]         @relation("BudgetCreatedBy")
  budgetsUpdated             CampaignBudget[]         @relation("BudgetUpdatedBy")
  budgetLinesOwned           BudgetLine[]             @relation("BudgetLineOwner")
  financeExpensesEntered     FinanceExpense[]         @relation("ExpenseEnteredBy")
  financeExpensesApproved    FinanceExpense[]         @relation("ExpenseApprovedBy")
  purchaseRequestsMade       FinancePurchaseRequest[] @relation("PurchaseRequestedBy")
  purchaseRequestsDecided    FinancePurchaseRequest[] @relation("PurchaseApprovedBy")
  financeReimbursements      FinanceReimbursement[]   @relation("ReimbursementUser")
  reimbursementsDecided      FinanceReimbursement[]   @relation("ReimbursementApprover")
  budgetTransfersRequested   BudgetTransfer[]         @relation("TransferRequestedBy")
  budgetTransfersApproved    BudgetTransfer[]         @relation("TransferApprovedBy")
  financeAssetsUploaded      FinanceAsset[]           @relation("AssetUploadedBy")

  // Calendar Suite
  calendarItemsCreated       CalendarItem[]           @relation("CalendarItemCreator")
  calendarItemsUpdated       CalendarItem[]           @relation("CalendarItemUpdater")
  calendarAssignments        CalendarItemAssignment[]
  availabilityBlocks         AvailabilityBlock[]
  conflictsResolved          ScheduleConflict[]       @relation("ConflictResolver")
  checklistEntriesCompleted  CalendarItemChecklistEntry[]
  calendarAuditActed         CalendarAuditLog[]       @relation("CalendarAuditActor")

  // CRM Suite
  contactNotesAuthored       ContactNote[]            @relation("ContactNoteAuthor")

  // Field Ops Domain
  fieldProgramsCreated        FieldProgram[]           @relation("FieldProgramCreatedBy")
  routesCreated               Route[]                  @relation("RouteCreatedBy")
  fieldShiftsLed              FieldShift[]             @relation("FieldShiftLead")
  fieldShiftAssignments       FieldShiftAssignment[]   @relation("FieldShiftAssignmentUser")
  scriptTemplatesCreated      ScriptTemplate[]         @relation("ScriptTemplateCreatedBy")
  scriptPackagesCreated       ScriptPackage[]          @relation("ScriptPackageCreatedBy")
  fieldAttemptsLogged         FieldAttempt[]           @relation("FieldAttemptLogger")
  followUpsAssigned           FollowUpAction[]         @relation("FollowUpAssignee")
  followUpsCompleted          FollowUpAction[]         @relation("FollowUpCompleter")
  fieldTeamsLed               FieldTeam[]              @relation("FieldTeamLead")
  fieldTeamsCreated           FieldTeam[]              @relation("FieldTeamCreatedBy")
  fieldTeamMemberships        FieldTeamMember[]        @relation("FieldTeamMemberUser")
  fieldAuditActed             FieldAuditLog[]          @relation("FieldAuditActor")
  messageTemplatesAuthored    MessageTemplate[]        @relation("MessageTemplateAuthor")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN
// ─────────────────────────────────────────────────────────────────────────────

model Campaign {
  id                     String       @id @default(cuid())
  name                   String
  slug                   String       @unique
  description            String?
  electionType           ElectionType @default(municipal)
  jurisdiction           String?
  electionDate           DateTime?
  // Election finance spending limits (from EC/provincial regulators)
  spendingLimit          Float?
  partyExpenseLimit      Float?
  candidateName          String?
  candidateTitle         String?
  candidateBio           String?
  candidateEmail         String?
  candidatePhone         String?
  logoUrl                String?
  websiteUrl             String?
  customDomain           String?
  volunteerIntroVideoUrl String?
  volunteerCodeOfConduct String?
  primaryColor           String       @default("#1e40af")
  isPublic               Boolean      @default(false)
  officialId             String?
  isActive               Boolean      @default(true)
  customization          Json?
  pageViews              Int          @default(0)
  // Per-campaign tracking IDs — campaigns paste their own analytics codes
  gaId                   String?      // Google Analytics 4 (G-XXXXXXXXXX)
  metaPixelId            String?      // Meta/Facebook Pixel ID
  googleAdsId            String?      // Google Ads tag (AW-XXXXXXXXXX)
  linkedinPartnerId      String?      // LinkedIn Insight Tag
  tiktokPixelId          String?      // TikTok Pixel
  // Domain verification
  domainStatus           String       @default("not_connected") // not_connected | pending | verified | live
  domainVerifiedAt       DateTime?
  votedDisplayMode       String       @default("strikethrough")
  onboardingComplete     Boolean      @default(false)
  isDemo                 Boolean      @default(false) // demo/simulation campaigns — sim engine only runs here
  // Setup wizard fields — captured during first-time onboarding
  officeAddress          String?      // physical campaign HQ address
  fromEmailName          String?      // display name for email blasts (e.g. "John Smith for Ward 5")
  replyToEmail           String?      // reply-to address for email blasts
  advanceVoteStart       DateTime?    // first day of advance voting window
  advanceVoteEnd         DateTime?    // last day of advance voting window
  // Campaign-level security enforcement
  require2FA             Boolean      @default(false)
  allowedIpRanges        String[]     @default([])
  sessionTimeoutHours    Int          @default(24)
  dataRetentionDays      Int          @default(365)
  // Brand Kit
  secondaryColor         String?      @default("#d71920")
  accentColor            String?      @default("#f5a623")
  logoPublicId           String?
  fontPrimary            String       @default("inter")
  tagline                String?
  twitterHandle          String?
  facebookUrl            String?
  instagramHandle        String?
  brandKitComplete       Boolean      @default(false)
  // TV Mode
  tvEnabled              Boolean      @default(false)
  tvToken                String?      @unique @default(cuid())
  tvRotate               Boolean      @default(true)
  tvRotateSec            Int          @default(30)
  tvModes                String[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  official                  Official?                  @relation(fields: [officialId], references: [id])
  memberships               Membership[]
  contacts                  Contact[]
  households                Household[]
  canvassLists              CanvassList[]
  tasks                     Task[]
  activityLogs              ActivityLog[]
  tags                      Tag[]
  signs                     Sign[]
  serviceBookings           ServiceBooking[]
  polls                     Poll[]
  campaignFields            CampaignField[]
  donations                 Donation[]
  gotvBatches               GotvBatch[]
  qrCodes                   QrCode[]
  volunteerProfiles         VolunteerProfile[]
  signRequests              SignRequest[]
  questions                 Question[]
  pushSubscriptions         PushSubscription[]
  notificationLogs          NotificationLog[]
  printJobs                 PrintJob[]
  turfs                     Turf[]
  volunteerLocations        VolunteerLocation[]
  mapSettings               MapSettings?
  volunteerOnboardingTokens VolunteerOnboardingToken[]
  volunteerGroups           VolunteerGroup[]
  volunteerShifts           VolunteerShift[]
  canvassingScripts         CanvassingScript[]
  mediaMentions             MediaMention[]
  coalitions                Coalition[]
  opponentIntel             OpponentIntel[]
  events                    Event[]
  socialAccounts            SocialAccount[]
  socialPosts               SocialPost[]
  socialMentions            SocialMention[]
  constituents              Constituent[]
  constituentCaseFiles      ConstituentCaseFile[]
  volunteerExpenses         VolunteerExpense[]
  budgetItems               BudgetItem[]
  budgetRules               BudgetRule[]
  budgetTemplates           BudgetTemplate[]
  contactFilterPresets      ContactFilterPreset[]
  superSupporterTasks       SuperSupporterTask[]
  importLogs                ImportLog[]
  exportLogs                ExportLog[]
  crmColumnPreferences      CrmColumnPreference[]
  importTemplates           CampaignImportTemplate[]
  documents                 CampaignDocument[]
  votedListTemplates        VotedListTemplate[]
  votedListUploads          VotedListUpload[]
  PrintOrder                PrintOrder[]
  MerchProduct              MerchProduct[]
  campaignRoles             CampaignRole[]
  permissionAuditLogs       PermissionAuditLog[]
  voiceBroadcasts           VoiceBroadcast[]
  voiceOptOuts              VoiceOptOut[]
  callCenterIntegrations    CallCenterIntegration[]
  phoneBankSessions         PhoneBankSession[]
  newsletterSubscribers     NewsletterSubscriber[]
  newsletterCampaigns       NewsletterCampaign[]
  forms                     Form[]
  scrutineerAssignments     ScrutineerAssignment[]
  liveResults               LiveResult[]
  fieldAssignments          FieldAssignment[]
  literaturePieces          LiteraturePiece[]
  literaturePackages        LiteraturePackage[]
  printInventory            PrintInventory[]
  printPacks                PrintPack[]
  signInventoryItems        SignInventoryItem[]
  // Alert routing: controls who receives which push notification types.
  // Schema: { "<alertType>": { "mode": "roles"|"users"|"all", "roles"?: Role[], "userIds"?: string[] } }
  // Default (null): falls back to all ADMIN + CAMPAIGN_MANAGER members.
  notificationRoutes        Json?

  // Fundraising Suite
  fundraisingCampaigns      FundraisingCampaign[]
  donorProfiles             DonorProfile[]
  donationSources           DonationSource[]
  donationPages             DonationPage[]
  recurrencePlans           RecurrencePlan[]
  pledges                   Pledge[]
  refunds                   Refund[]
  donationReceipts          DonationReceipt[]
  paymentReconciliations    PaymentReconciliation[]
  donorAuditLogs            DonorAuditLog[]

  // Finance
  campaignBudgets           CampaignBudget[]
  budgetLines               BudgetLine[]
  financeVendors            FinanceVendor[]
  financeExpenses           FinanceExpense[]
  financePurchaseRequests   FinancePurchaseRequest[]
  financePurchaseOrders     FinancePurchaseOrder[]
  financeVendorBills        FinanceVendorBill[]
  financeReimbursements     FinanceReimbursement[]
  budgetTransfers           BudgetTransfer[]
  financeAuditLogs          FinanceAuditLog[]
  financeAssets             FinanceAsset[]

  // Calendar Suite
  calendars                 Calendar[]
  calendarItems             CalendarItem[]
  availabilityBlocks        AvailabilityBlock[]
  scheduleConflicts         ScheduleConflict[]
  checklistTemplates        ChecklistTemplate[]
  calendarAuditLogs         CalendarAuditLog[]

  // CRM Suite
  contactNotes              ContactNote[]
  contactRelationships      ContactRelationship[]
  duplicateCandidates       DuplicateCandidate[]
  mergeHistories            MergeHistory[]
  contactAuditLogs          ContactAuditLog[]

  // Field Ops Domain
  fieldPrograms             FieldProgram[]
  fieldRoutes               Route[]
  fieldTargets              FieldTarget[]
  fieldShifts               FieldShift[]
  fieldShiftAssignments     FieldShiftAssignment[]
  scriptTemplates           ScriptTemplate[]
  scriptPackages            ScriptPackage[]
  fieldAttempts             FieldAttempt[]
  followUpActions           FollowUpAction[]
  fieldTeams                FieldTeam[]
  fieldTeamMembers          FieldTeamMember[]
  fieldAuditLogs            FieldAuditLog[]
  messageTemplates          MessageTemplate[]

  @@unique([customDomain])
  @@index([slug])
  @@index([isPublic, isActive])
  @@map("campaigns")
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  campaignId     String
  role           Role     @default(VOLUNTEER)
  campaignRoleId String?
  trustLevel     Int      @default(2)
  status         String   @default("active")
  joinedAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignRole  CampaignRole? @relation(fields: [campaignRoleId], references: [id])
  assignedTurfs Turf[]        @relation("TurfAssignedVolunteer")

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@map("memberships")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAMPAIGN ROLES & PERMISSIONS (Enterprise RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model CampaignRole {
  id           String   @id @default(cuid())
  campaignId   String
  name         String
  slug         String
  description  String?
  colour       String   @default("#6b7280")
  permissions  String[]
  trustFloor   Int      @default(1)
  trustCeiling Int      @default(5)
  isSystem     Boolean  @default(false)
  isDefault    Boolean  @default(false)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([campaignId, slug])
  @@index([campaignId])
  @@map("campaign_roles")
}

model PermissionAuditLog {
  id           String   @id @default(cuid())
  campaignId   String
  actorUserId  String
  targetUserId String?
  action       String
  before       Json?
  after        Json?
  reason       String?
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@map("permission_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// OFFICIALS / ELECTED REPRESENTATIVES
// ─────────────────────────────────────────────────────────────────────────────

model Official {
  id                 String          @id @default(cuid())
  name               String
  title              String // e.g. "Mayor", "MP", "MPP", "Councillor"
  level              GovernmentLevel
  district           String // ward, riding, or constituency name
  districtCode       String? // official electoral district code
  party              String? // legacy field
  partyName          String? // canonical party name — used for colour lookup
  email              String?
  phone              String?
  website            String?
  photoUrl           String?
  bio                String?
  // Geographic coverage
  postalCodes        String[]        @default([]) // postal prefixes served
  province           String?
  // Profile status
  isClaimed          Boolean         @default(false)
  claimedAt          DateTime?
  claimedByUserId    String?
  subscriptionStatus String?         @default("free") // free | pro | verified
  isActive           Boolean         @default(true)
  // Social media
  twitter            String?
  facebook           String?
  instagram          String?
  linkedIn           String?
  // Extended identity fields
  firstName          String?
  lastName           String?
  address            String?
  // External data provenance
  externalId         String? // e.g. Represent API slug
  externalSource     String? // "represent_opennorth" | "manual" | "open_north"
  termStart          DateTime?
  termEnd            DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  campaigns        Campaign[]
  follows          OfficialFollow[]
  questions        PublicQuestion[]
  polls            Poll[]
  approvalRating   ApprovalRating?
  sentimentSignals SentimentSignal[]
  outreach         OfficialOutreach[]
  constituents     Constituent[]
  caseFiles                ConstituentCaseFile[]
