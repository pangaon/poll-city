  vendor          FinanceVendor?         @relation(fields: [vendorId], references: [id])
  budgetLine      BudgetLine?            @relation(fields: [budgetLineId], references: [id])
  purchaseRequest FinancePurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  expenses        FinanceExpense[]
