{
  "expo": {
    "name": "Poll City",
    "slug": "poll-city-canvasser",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pollcity",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ca.pollcity.canvasser",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Poll City uses your location to show your position on the canvassing map and track your route through the turf.",
        "NSCameraUsageDescription": "Poll City uses your camera to photograph lawn signs and scan voted lists.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:www.poll.city",
        "applinks:app.poll.city"
      ],
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "ca.pollcity.canvasser",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.poll.city",
              "pathPrefix": "/canvass"
            },
            {
              "scheme": "https",
              "host": "app.poll.city",
              "pathPrefix": "/canvass"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-sqlite",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34,
            "compileSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://app.poll.city"
      },
      "EXPO_PUBLIC_API_URL": "https://app.poll.city",
      "eas": {
        "projectId": "c7b82bca-5d63-444f-95f1-c48bbcd30f8f"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/c7b82bca-5d63-444f-95f1-c48bbcd30f8f"
    },
    "owner": "pollcity",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
