# Poll City Mobile — Environment Variables
#
# Copy this file to .env.local and fill in the values.
# For local development, use your machine's local IP (not localhost)
# so the phone/emulator can reach the Next.js dev server.
#   e.g. EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
#
# For production, use your Vercel deployment URL.

EXPO_PUBLIC_API_URL=https://your-app.vercel.app
